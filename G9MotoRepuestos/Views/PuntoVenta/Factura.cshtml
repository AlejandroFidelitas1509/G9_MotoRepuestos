@model G9MotoRepuestos.Models.ViewModels.FacturaVm
@{
    ViewData["Title"] = "Factura";
}

<div class="container mt-4">

    @if (TempData["Ok"] != null)
    {
        <div class="alert alert-success">@TempData["Ok"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-danger fw-bold">Factura #@Model.IdVenta</h2>

        <div class="d-flex gap-2">
            <a class="btn btn-secondary" asp-controller="PuntoVenta" asp-action="Index">Volver al POS</a>

            <a class="btn btn-danger"
               target="_blank"
               asp-controller="PuntoVenta"
               asp-action="FacturaPdf"
               asp-route-id="@Model.IdVenta">
                Ver / Descargar PDF
            </a>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <div><b>Fecha:</b> @Model.Fecha.ToString("yyyy-MM-dd HH:mm")</div>
            <div><b>Forma de pago:</b> @Model.FormaPago</div>
            <div><b>Estado:</b> @Model.Estado</div>
            <hr />
            <div><b>Subtotal:</b> ₡ @Model.Subtotal.ToString("N2")</div>
            <div><b>IVA:</b> ₡ @Model.Impuesto.ToString("N2")</div>
            <div><b>Descuento:</b> ₡ @Model.Descuento.ToString("N2")</div>
            <div class="fs-4 fw-bold text-danger"><b>Total:</b> ₡ @Model.Total.ToString("N2")</div>
        </div>
   

    </div>

    <div class="card">
        <div class="card-header bg-dark text-white fw-bold">
            Vista previa del PDF
        </div>
        <div class="card-body p-0">
            <iframe src="@Url.Action("FacturaPdf", "PuntoVenta", new { id = Model.IdVenta })"
                    style="width:100%; height:700px; border:none;">
            </iframe>
        </div>
    </div>

</div>
