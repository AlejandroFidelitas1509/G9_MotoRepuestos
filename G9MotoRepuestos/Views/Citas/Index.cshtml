@using MR.LogicaNegocio.Dtos
@model List<CitasDto>

@{
    ViewData["Title"] = "Listado de Citas";
}

<link rel="stylesheet" href="~/css/Citas.css" />


<h2 class="text-center fw-bold mb-4">Listado de Citas</h2>


<div class="table-container">
    <table id="tablaCitas"  class="table">
        <a asp-controller="Citas" asp-action="Create" class="btn btn-danger fw-bold mt-3 mb-3">NUEVA CITA</a>
        <thead>
            <tr>
                <th>Id</th>
                <th>Detalle</th>
                <th>Fecha y Hora</th>
                <th>Modelo</th>
                <th>Placa</th>
                <th>Estado</th>
                <th>Usuario</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cita in Model)
            {
                <tr>
                    <td>@cita.IdCita</td>
                    <td>@cita.Detalle</td>
                    <td>@cita.Fecha.ToString("ddd-dd-MMM-yyyy HH:mm")</td>
                    <td>@cita.Modelo</td>
                    <td>@cita.Placa</td>
                    <td>
                        @(cita.Estado == 0 ? "Pendiente" :
                                            cita.Estado == 1 ? "En Revision" :
                                            cita.Estado == 2 ? "Finalizada" : "Desconocido")
                </td>
                <td>@cita.IdUsuario</td>
                <td>
                    <!-- Botón Editar con ícono -->
                    <a asp-action="Edit" asp-route-id="@cita.IdCita" class="btn btn-sm btn-warning me-2">
                        <i class="fas fa-edit"></i>
                    </a>

                        <!-- Botón Eliminar con ícono -->
                        <a asp-action="Delete" asp-route-id="@cita.IdCita" class="btn btn-sm btn-danger">
                            <i class="fas fa-trash-alt"></i>
                        </a>
                    </td>
            </tr>
                        }
        </tbody>
    </table>
</div>
@section Scripts {
    <!-- jQuery primero -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <!-- DataTables después -->
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />

    <!-- Tu script personalizado -->
    <script src="~/js/citas/citas.js"></script>

}




