@using MR.LogicaNegocio.Dtos
@model List<CitasDto>

@{
    ViewData["Title"] = "Listado de Citas";
}

<style>
    .ct-wrap {
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

    .ct-hero {
        background: #fff;
        border: 1px solid #dde3ee;
        border-radius: 14px;
        box-shadow: 0 1px 4px rgba(0,0,0,.05);
        padding: 20px 22px;
    }

    .ct-kicker {
        font-size: 13px;
        font-weight: 700;
        color: #8a94a6;
        text-transform: uppercase;
        letter-spacing: .05em;
        margin-bottom: 6px;
    }

    .ct-title {
        font-size: 28px;
        font-weight: 800;
        color: #1a202c;
        margin: 0;
    }

    .ct-sub {
        font-size: 15px;
        color: #6b7280;
        margin-top: 6px;
    }

    .ct-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
    }

    .ct-btn-main {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 11px 18px;
        border-radius: 10px;
        background: #c92a2a;
        color: #fff;
        text-decoration: none;
        font-size: 14px;
        font-weight: 700;
        border: none;
        transition: background .15s ease, transform .15s ease;
    }

        .ct-btn-main:hover {
            background: #a61e1e;
            color: #fff;
            transform: translateY(-1px);
        }

    .ct-table-card {
        background: #fff;
        border: 1px solid #dde3ee;
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 1px 4px rgba(0,0,0,.05);
    }

    .ct-table-head {
        padding: 16px 20px;
        border-bottom: 1px solid #edf0f7;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        flex-wrap: wrap;
    }

    .ct-table-title {
        font-size: 16px;
        font-weight: 700;
        color: #1a202c;
    }

    .ct-table-sub {
        font-size: 14px;
        color: #6b7280;
        margin-top: 3px;
    }

    .ct-badge-info {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #f8fafd;
        border: 1px solid #dde3ee;
        color: #4a5568;
        border-radius: 999px;
        padding: 7px 12px;
        font-size: 13px;
        font-weight: 700;
    }

    .ct-table-wrap {
        padding: 0 0 4px 0;
    }

    #tablaCitas {
        width: 100% !important;
        margin: 0 !important;
        border-collapse: collapse !important;
    }

        #tablaCitas thead th {
            background: #f8fafd !important;
            color: #8a94a6 !important;
            font-size: 12px !important;
            font-weight: 700 !important;
            text-transform: uppercase;
            letter-spacing: .06em;
            border-bottom: 1px solid #edf0f7 !important;
            padding: 14px 16px !important;
            white-space: nowrap;
        }

        #tablaCitas tbody td {
            padding: 16px 16px !important;
            border-bottom: 1px solid #f0f3f9 !important;
            vertical-align: middle !important;
            color: #4a5568;
            font-size: 14px;
        }

        #tablaCitas tbody tr:last-child td {
            border-bottom: none !important;
        }

        #tablaCitas tbody tr:hover td {
            background: #f4f7fc !important;
        }

    .ct-id {
        font-weight: 700;
        color: #1a202c;
    }

    .ct-detail {
        font-weight: 600;
        color: #1a202c;
    }

    .ct-date {
        white-space: nowrap;
        font-weight: 600;
        color: #4a5568;
    }

    .ct-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 5px 11px;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 700;
        white-space: nowrap;
        border: 1px solid transparent;
    }

    .ct-pendiente {
        background: #fff7ed;
        color: #9a3412;
        border-color: #fed7aa;
    }

    .ct-revision {
        background: #eff6ff;
        color: #1d4ed8;
        border-color: #bfdbfe;
    }

    .ct-finalizada {
        background: #f0fdf4;
        color: #166534;
        border-color: #bbf7d0;
    }

    .ct-desconocido {
        background: #f4f7fc;
        color: #4a5568;
        border-color: #dde3ee;
    }

    .ct-user {
        font-weight: 600;
        color: #1a202c;
    }

    .ct-actions {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        flex-wrap: wrap;
    }

    .ct-icon-btn {
        width: 34px;
        height: 34px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        border-radius: 8px;
        border: 1px solid #dde3ee;
        background: #f8fafd;
        color: #4a5568;
        text-decoration: none;
        cursor: pointer;
        transition: all .15s ease;
    }

        .ct-icon-btn:hover {
            background: #fff;
            border-color: #b8c4d8;
            transform: translateY(-1px);
            box-shadow: 0 2px 6px rgba(0,0,0,.08);
            color: #1a202c;
            text-decoration: none;
        }

    .ct-modal .modal-dialog {
        max-width: 560px;
    }

        .ct-modal .modal-dialog.ct-modal-sm {
            max-width: 460px;
        }

    .ct-modal .modal-content {
        border: 1px solid #dde3ee;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 18px 45px rgba(0,0,0,.18);
    }

    .ct-modal .modal-header {
        background: linear-gradient(135deg, #162033 0%, #1f2937 100%);
        color: #fff;
        border-bottom: none;
        padding: 16px 20px;
    }

    .ct-modal-title {
        font-size: 20px;
        font-weight: 800;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .ct-modal .modal-body {
        padding: 22px 20px 18px 20px;
        background: #fff;
    }

    .ct-modal .modal-footer {
        border-top: 1px solid #edf0f7;
        padding: 14px 20px 18px 20px;
        background: #fff;
    }

    .ct-field {
        display: flex;
        flex-direction: column;
        gap: 6px;
        margin-bottom: 15px;
    }

        .ct-field:last-child {
            margin-bottom: 0;
        }

    .ct-label {
        font-size: 14px;
        font-weight: 700;
        color: #4a5568;
    }

    .ct-input,
    .ct-select {
        width: 100%;
        background: #f8fafd;
        border: 1px solid #dde3ee;
        border-radius: 10px;
        color: #1a202c;
        font-size: 14px;
        padding: 11px 12px;
        transition: border-color .15s ease, box-shadow .15s ease, background .15s ease;
    }

        .ct-input:focus,
        .ct-select:focus {
            background: #fff;
            outline: none;
            border-color: rgba(201,42,42,.4);
            box-shadow: 0 0 0 3px rgba(201,42,42,.08);
        }

    .ct-modal-note {
        font-size: 14px;
        color: #6b7280;
        margin-bottom: 16px;
    }

    .ct-delete-note {
        font-size: 15px;
        color: #4a5568;
        line-height: 1.55;
    }

    .ct-delete-name {
        font-weight: 800;
        color: #1a202c;
    }

    .ct-btn-secondary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        padding: 10px 16px;
        border-radius: 10px;
        background: #f4f7fc;
        border: 1px solid #dde3ee;
        color: #4a5568;
        text-decoration: none;
        font-size: 14px;
        font-weight: 700;
    }

        .ct-btn-secondary:hover {
            background: #fff;
            color: #1a202c;
        }

    .ct-btn-save {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        padding: 10px 16px;
        border-radius: 10px;
        background: #c92a2a;
        border: 1px solid #c92a2a;
        color: #fff;
        text-decoration: none;
        font-size: 14px;
        font-weight: 700;
    }

        .ct-btn-save:hover {
            background: #a61e1e;
            border-color: #a61e1e;
            color: #fff;
        }

    .ct-btn-delete-confirm {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        padding: 10px 16px;
        border-radius: 10px;
        background: #fff1f1;
        border: 1px solid #fecaca;
        color: #991b1b;
        text-decoration: none;
        font-size: 14px;
        font-weight: 700;
    }

        .ct-btn-delete-confirm:hover {
            background: #fee2e2;
            color: #7f1d1d;
        }

    .dataTables_wrapper .row:first-child {
        display: flex !important;
        align-items: center !important;
        justify-content: space-between !important;
        margin: 0 !important;
        padding: 16px 20px 10px 20px;
        gap: 12px;
        flex-wrap: wrap;
    }

        .dataTables_wrapper .row:first-child > div {
            width: auto !important;
            max-width: none !important;
            flex: 1 1 0 !important;
            padding-left: 0 !important;
            padding-right: 0 !important;
        }

            .dataTables_wrapper .row:first-child > div:first-child {
                order: 2;
                display: flex !important;
                justify-content: flex-end !important;
                margin-left: auto !important;
                text-align: right !important;
            }

            .dataTables_wrapper .row:first-child > div:last-child {
                order: 1;
                display: flex !important;
                justify-content: flex-start !important;
                margin-right: auto !important;
                text-align: left !important;
            }

        .dataTables_wrapper .row:first-child .dataTables_filter,
        .dataTables_wrapper .row:first-child .dataTables_length {
            padding: 0 !important;
            margin: 0 !important;
        }

    .dataTables_wrapper .dataTables_length label,
    .dataTables_wrapper .dataTables_filter label {
        font-size: 14px;
        font-weight: 600;
        color: #4a5568;
        margin: 0 !important;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .dataTables_wrapper .dataTables_filter input,
    .dataTables_wrapper .dataTables_length select {
        background: #f8fafd !important;
        border: 1px solid #dde3ee !important;
        border-radius: 9px !important;
        color: #1a202c !important;
        padding: 8px 10px !important;
        font-size: 14px !important;
        margin-left: 0 !important;
        box-shadow: none !important;
    }

        .dataTables_wrapper .dataTables_filter input:focus,
        .dataTables_wrapper .dataTables_length select:focus {
            background: #fff !important;
            border-color: rgba(201,42,42,.4) !important;
            box-shadow: 0 0 0 3px rgba(201,42,42,.08) !important;
            outline: none !important;
        }

    .dataTables_wrapper .dataTables_info {
        padding: 14px 20px 18px 20px !important;
        font-size: 14px !important;
        color: #6b7280 !important;
    }

    .dataTables_wrapper .dataTables_paginate {
        padding: 10px 20px 18px 20px !important;
    }

    .dataTables_wrapper .paginate_button {
        border: none !important;
        background: transparent !important;
        box-shadow: none !important;
        padding: 0 !important;
        margin-left: 6px !important;
    }

        .dataTables_wrapper .paginate_button .page-link,
        .dataTables_wrapper .paginate_button {
            border-radius: 9px !important;
        }

            .dataTables_wrapper .paginate_button.current,
            .dataTables_wrapper .paginate_button.current:hover {
                background: #c92a2a !important;
                border: 1px solid #c92a2a !important;
                color: #fff !important;
                border-radius: 9px !important;
            }

            .dataTables_wrapper .paginate_button:hover {
                background: #f8fafd !important;
                color: #1a202c !important;
            }

    @@media (max-width: 768px) {
        .ct-title {
            font-size: 24px;
        }

        .ct-toolbar {
            align-items: stretch;
        }

        .ct-btn-main {
            justify-content: center;
            width: 100%;
        }

        .ct-actions {
            flex-direction: row;
        }

        .dataTables_wrapper .row:first-child {
            display: block !important;
            padding: 16px 20px 10px 20px;
        }

            .dataTables_wrapper .row:first-child > div {
                width: 100% !important;
                max-width: 100% !important;
                flex: 0 0 100% !important;
                margin: 0 0 10px 0 !important;
                text-align: left !important;
                justify-content: flex-start !important;
            }

                .dataTables_wrapper .row:first-child > div:first-child,
                .dataTables_wrapper .row:first-child > div:last-child {
                    order: initial;
                }

        .dataTables_wrapper .dataTables_length label,
        .dataTables_wrapper .dataTables_filter label {
            flex-wrap: wrap;
            justify-content: flex-start;
        }
    }
</style>

<div class="ct-wrap">

    <div class="ct-hero">
        <div class="ct-toolbar">
            <div>
                <div class="ct-kicker">Gestión</div>
                <h1 class="ct-title">Listado de Citas</h1>
                <div class="ct-sub">Consulta, edita o elimina las citas registradas en el sistema.</div>
            </div>

            <button type="button" class="ct-btn-main" data-bs-toggle="modal" data-bs-target="#modalNuevaCita">
                <i class="fas fa-plus"></i>
                Nueva cita
            </button>
        </div>
    </div>

    <div class="ct-table-card">
        <div class="ct-table-head">
            <div>
                <div class="ct-table-title">
                    <i class="fas fa-calendar-alt me-2" style="color:#c92a2a"></i>
                    Citas registradas
                </div>
                <div class="ct-table-sub">Visualiza la programación actual y administra cada cita.</div>
            </div>

            <span class="ct-badge-info">
                <i class="fas fa-list"></i>
                Total: @Model.Count
            </span>
        </div>

        <div class="ct-table-wrap">
            <table id="tablaCitas" class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Detalle</th>
                        <th>Fecha y hora</th>
                        <th>Modelo</th>
                        <th>Placa</th>
                        <th>Estado</th>
                        <th>Usuario</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cita in Model)
                    {
                        var estadoTexto = cita.Estado == 0 ? "Pendiente"
                        : cita.Estado == 1 ? "En revisión"
                        : cita.Estado == 2 ? "Finalizada"
                        : "Desconocido";

                        var estadoClase = cita.Estado == 0 ? "ct-pendiente"
                        : cita.Estado == 1 ? "ct-revision"
                        : cita.Estado == 2 ? "ct-finalizada"
                        : "ct-desconocido";

                        <tr>
                            <td class="ct-id">#@cita.IdCita</td>
                            <td class="ct-detail">@cita.Detalle</td>
                            <td class="ct-date">@cita.Fecha.ToString("ddd dd MMM yyyy HH:mm")</td>
                            <td>@cita.Modelo</td>
                            <td>@cita.Placa</td>
                            <td>
                                <span class="ct-pill @estadoClase">@estadoTexto</span>
                            </td>
                            <td class="ct-user">@cita.IdUsuario</td>
                            <td class="text-center">
                                <div class="ct-actions">
                                    <button type="button"
                                            class="ct-icon-btn"
                                            title="Editar"
                                            data-bs-toggle="modal"
                                            data-bs-target="#modalEditarCita-@cita.IdCita">
                                        <i class="fas fa-pen"></i>
                                    </button>

                                    <button type="button"
                                            class="ct-icon-btn"
                                            title="Eliminar"
                                            data-bs-toggle="modal"
                                            data-bs-target="#modalEliminarCita-@cita.IdCita">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade ct-modal" id="modalNuevaCita" tabindex="-1" aria-labelledby="modalNuevaCitaLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="ct-modal-title" id="modalNuevaCitaLabel">
                    <i class="fas fa-plus" style="color:#86efac;"></i>
                    Nueva cita
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>

            <form asp-controller="Citas" asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div class="modal-body">
                    <div class="ct-modal-note">
                        Completa la información de la cita sin salir del listado.
                    </div>

                    <div class="ct-field">
                        <label class="ct-label" for="Detalle">Servicio</label>
                        <select name="Detalle" id="Detalle" class="ct-select" required>
                            <option value="">Seleccione un servicio</option>
                            <option value="Cambio de aceite">Cambio de aceite</option>
                            <option value="Revisión eléctrica">Revisión Eléctrica</option>
                            <option value="Mantenimiento general">Mantenimiento General</option>
                            <option value="Cambio de fibras y frenos">Cambio de Fibras y frenos</option>
                        </select>
                    </div>

                    <div class="ct-field">
                        <label class="ct-label" for="Fecha">Fecha y hora</label>
                        <input name="Fecha" id="Fecha" type="datetime-local" class="ct-input" required />
                    </div>

                    <div class="ct-field">
                        <label class="ct-label" for="Modelo">Modelo</label>
                        <input name="Modelo" id="Modelo" class="ct-input" required />
                    </div>

                    <div class="ct-field">
                        <label class="ct-label" for="Placa">Placa</label>
                        <input name="Placa" id="Placa" class="ct-input" required />
                    </div>

                    <div class="ct-field">
                        <label class="ct-label" for="Estado">Estado</label>
                        <select name="Estado" id="Estado" class="ct-select">
                            <option value="0">Pendiente</option>
                            <option value="1">En revisión</option>
                            <option value="2">Finalizada</option>
                        </select>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="ct-btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="ct-btn-save">
                        <i class="fas fa-save"></i>
                        Guardar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@foreach (var cita in Model)
{
    <div class="modal fade ct-modal" id="modalEditarCita-@cita.IdCita" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="ct-modal-title">
                        <i class="fas fa-pen" style="color:#fcd34d;"></i>
                        Editar cita #@cita.IdCita
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>

                <form asp-controller="Citas" asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="IdCita" value="@cita.IdCita" />

                    <div class="modal-body">
                        <div class="ct-modal-note">
                            Modifica la información de la cita desde esta ventana flotante.
                        </div>

                        <div class="ct-field">
                            <label class="ct-label" for="Detalle-@cita.IdCita">Servicio</label>
                            <select name="Detalle" id="Detalle-@cita.IdCita" class="ct-select" required>
                                <option value="">Seleccione un servicio</option>
                                <option value="Cambio de aceite" selected="@(cita.Detalle == "Cambio de aceite" ? "selected" : null)">Cambio de aceite</option>
                                <option value="Revisión eléctrica" selected="@(cita.Detalle == "Revisión eléctrica" ? "selected" : null)">Revisión Eléctrica</option>
                                <option value="Mantenimiento general" selected="@(cita.Detalle == "Mantenimiento general" ? "selected" : null)">Mantenimiento General</option>
                                <option value="Cambio de fibras y frenos" selected="@(cita.Detalle == "Cambio de fibras y frenos" ? "selected" : null)">Cambio de Fibras y frenos</option>
                            </select>
                        </div>

                        <div class="ct-field">
                            <label class="ct-label" for="Fecha-@cita.IdCita">Fecha y hora</label>
                            <input name="Fecha" id="Fecha-@cita.IdCita" type="datetime-local" class="ct-input" value="@cita.Fecha.ToString("yyyy-MM-ddTHH:mm")" required />
                        </div>

                        <div class="ct-field">
                            <label class="ct-label" for="Modelo-@cita.IdCita">Modelo</label>
                            <input name="Modelo" id="Modelo-@cita.IdCita" class="ct-input" value="@cita.Modelo" required />
                        </div>

                        <div class="ct-field">
                            <label class="ct-label" for="Placa-@cita.IdCita">Placa</label>
                            <input name="Placa" id="Placa-@cita.IdCita" class="ct-input" value="@cita.Placa" required />
                        </div>

                        <div class="ct-field">
                            <label class="ct-label" for="Estado-@cita.IdCita">Estado</label>
                            <select name="Estado" id="Estado-@cita.IdCita" class="ct-select">
                                <option value="0" selected="@(cita.Estado == 0 ? "selected" : null)">Pendiente</option>
                                <option value="1" selected="@(cita.Estado == 1 ? "selected" : null)">En revisión</option>
                                <option value="2" selected="@(cita.Estado == 2 ? "selected" : null)">Finalizada</option>
                            </select>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="ct-btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="ct-btn-save">
                            <i class="fas fa-save"></i>
                            Guardar cambios
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade ct-modal" id="modalEliminarCita-@cita.IdCita" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered ct-modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="ct-modal-title">
                        <i class="fas fa-trash" style="color:#fca5a5;"></i>
                        Eliminar cita
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>

                <form asp-controller="Citas" asp-action="Delete" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@cita.IdCita" />

                    <div class="modal-body">
                        <div class="ct-delete-note">
                            żDeseas eliminar la cita <span class="ct-delete-name">#@cita.IdCita</span> de <span class="ct-delete-name">@cita.Modelo</span>?
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="ct-btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="ct-btn-delete-confirm">
                            <i class="fas fa-trash"></i>
                            Eliminar
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {
            if ($.fn.DataTable.isDataTable('#tablaCitas')) {
                $('#tablaCitas').DataTable().destroy();
            }

            $('#tablaCitas').DataTable({
                pageLength: 5,
                lengthMenu: [5, 10, 15, 20],
                ordering: true,
                responsive: false,
                language: {
                    search: "Buscar:",
                    lengthMenu: "Mostrar _MENU_ registros",
                    info: "Mostrando _START_ a _END_ de _TOTAL_ registros",
                    infoEmpty: "Mostrando 0 a 0 de 0 registros",
                    infoFiltered: "(filtrado de _MAX_ registros totales)",
                    zeroRecords: "No se encontraron citas",
                    emptyTable: "No hay citas registradas",
                    paginate: {
                        first: "Primero",
                        last: "Último",
                        next: "Siguiente",
                        previous: "Anterior"
                    }
                }
            });
        });
    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}