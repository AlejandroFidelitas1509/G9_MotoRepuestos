@using MR.LogicaNegocio.Dtos
@model CitasDto

@{
    ViewData["Title"] = "Editar Información de Cita";
    bool esAdmin = User.IsInRole("Admin") || User.IsInRole("Administrador");
}

<div class="container mt-4">
    <div class="card shadow-lg border-0">
        <div class="card-body">
            <!-- Título principal con subrayado rojo animado -->
            <h2 class="text-dark fw-bold mb-4 text-center position-relative d-inline-block">
                Editar información de la cita
                <span class="underline-red"></span>
            </h2>

            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="IdCita" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Detalle" class="form-label"></label>
                        <input asp-for="Detalle" class="form-control" />
                        <span asp-validation-for="Detalle" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Fecha" class="form-label"></label>
                        <input asp-for="Fecha" class="form-control" type="datetime-local" />
                        <span asp-validation-for="Fecha" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Modelo" class="form-label"></label>
                        <input asp-for="Modelo" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Placa" class="form-label"></label>
                        <input asp-for="Placa" class="form-control" />
                    </div>
                </div>

                @if (esAdmin)
                {
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Estado" class="form-label"></label>
                            <select asp-for="Estado" class="form-select">
                                <option value="0">Pendiente</option>
                                <option value="1">En Revisión</option>
                                <option value="2">Finalizada</option>
                            </select>
                        </div>
                    </div>
                }

                <div class="d-flex justify-content-end mt-3">
                    <button type="submit" class="btn btn-danger me-2">Guardar</button>
                    <a asp-action="Index" class="btn btn-secondary">Volver</a>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Estilos para la animación con transición -->
<style>
    .underline-red {
        display: block;
        margin: 8px auto 0 auto;
        height: 4px;
        width: 0;
        background-color: #dc3545; /* Rojo Bootstrap */
        transition: width 1s ease-out;
    }

        .underline-red.loaded {
            width: 60px;
        }

    h2:hover .underline-red {
        width: 100px;
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        document.querySelector(".underline-red").classList.add("loaded");
    });
</script>