@using MR.LogicaNegocio.Dtos
@model CitasDto

@{
    ViewData["Title"] = "Eliminar Cita";
}

<div class="container d-flex justify-content-center align-items-center mt-5">
    <div class="card shadow-lg border-0" style="max-width: 600px; width: 100%;">
        <div class="card-body text-center">
            <!-- Título principal -->
            <h2 class="text-dark fw-bold mb-3">Eliminar Cita</h2>
            <h5 class="text-muted mb-4">żEstá seguro que deseas eliminar esta cita?</h5>

            <!-- Detalles de la cita -->
            <dl class="row text-start">
                <dt class="col-sm-4 fw-bold">Detalle</dt>
                <dd class="col-sm-8">@Model.Detalle</dd>

                <dt class="col-sm-4 fw-bold">Fecha</dt>
                <dd class="col-sm-8">@Model.Fecha</dd>

                <dt class="col-sm-4 fw-bold">Modelo</dt>
                <dd class="col-sm-8">@Model.Modelo</dd>

                <dt class="col-sm-4 fw-bold">Placa</dt>
                <dd class="col-sm-8">@Model.Placa</dd>

                <dt class="col-sm-4 fw-bold">Estado</dt>
                <dd class="col-sm-8">
                    @(Model.Estado == 0 ? "Pendiente" :
                                        Model.Estado == 1 ? "Terminada" : "Cancelada")
                </dd>
            </dl>

            <!-- Botones de acción -->
            <form asp-action="Delete" method="post" class="mt-4">
                <input type="hidden" asp-for="IdCita" />
                <button type="submit" class="btn btn-danger me-2">Eliminar</button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </form>
        </div>
    </div>
</div>