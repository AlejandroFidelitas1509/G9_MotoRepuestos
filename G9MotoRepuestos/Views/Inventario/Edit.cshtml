@using MR.Abstracciones.EntidadesParaUI
@using Microsoft.AspNetCore.Mvc.Rendering
@model ProductoDto

@{
    ViewData["Title"] = "Editar Producto";
    var tieneImagen = !string.IsNullOrWhiteSpace(Model.ImageURL);
}

<style>
    .cp-page {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .cp-layout {
        display: grid;
        grid-template-columns: minmax(0, 1.7fr) minmax(320px, .95fr);
        gap: 20px;
        align-items: start;
    }

    .left-stack,
    .right-stack {
        display: flex;
        flex-direction: column;
        gap: 16px;
        min-width: 0;
    }

    .form-card,
    .img-card {
        background: #fff;
        border: 1px solid #dde3ee;
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 1px 4px rgba(0,0,0,.05);
    }

    .form-card-header {
        padding: 14px 18px;
        border-bottom: 1px solid #edf0f7;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .hdr-icon {
        width: 34px;
        height: 34px;
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        flex-shrink: 0;
    }

    .form-card-body {
        padding: 18px;
    }

    .field {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

        .field label {
            font-size: 12px !important;
            font-weight: 600 !important;
            color: #4a5568 !important;
            text-transform: uppercase;
            letter-spacing: .05em;
        }

        .field input,
        .field select,
        .field textarea {
            background: #f8fafd !important;
            border: 1px solid #dde3ee !important;
            border-radius: 9px !important;
            color: #1a202c !important;
            font-size: 14px !important;
            padding: 10px 12px !important;
            transition: border-color .15s, box-shadow .15s, background .15s;
            width: 100%;
        }

            .field input:focus,
            .field select:focus,
            .field textarea:focus {
                background: #fff !important;
                outline: none !important;
                border-color: rgba(201,42,42,.4) !important;
                box-shadow: 0 0 0 3px rgba(201,42,42,.08) !important;
            }

            .field input::placeholder,
            .field textarea::placeholder {
                color: #b0b8c8 !important;
            }

        .field .text-danger {
            font-size: 11px !important;
            color: #c92a2a !important;
        }

    .field-row {
        display: grid;
        gap: 12px;
    }

    .field-row-2 {
        grid-template-columns: 1fr 1fr;
    }

    .field-row-3 {
        grid-template-columns: 1fr 1fr 1fr;
    }

    .hint {
        font-size: 11px;
        color: #8a94a6;
        margin-top: 2px;
    }

    .id-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #fff1f1;
        border: 1px solid #fecaca;
        color: #991b1b;
        font-size: 12px;
        font-weight: 700;
        padding: 3px 10px;
        border-radius: 99px;
    }

    .tips-panel {
        background: linear-gradient(135deg, #c92a2a 0%, #a61e1e 55%, #1e2a4a 100%);
        border-radius: 14px;
        padding: 16px 18px;
        box-shadow: 0 4px 16px rgba(201,42,42,.18);
        position: relative;
        overflow: hidden;
    }

        .tips-panel::after {
            content: '';
            position: absolute;
            bottom: -28px;
            right: -28px;
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(255,255,255,.1) 0%, transparent 70%);
            pointer-events: none;
        }

    .tip-row {
        display: flex;
        align-items: flex-start;
        gap: 8px;
        font-size: 12px;
        color: rgba(255,255,255,.9);
        line-height: 1.45;
        margin-bottom: 7px;
    }

        .tip-row:last-child {
            margin-bottom: 0;
        }

        .tip-row i {
            font-size: 10px;
            margin-top: 3px;
            opacity: .8;
            flex-shrink: 0;
        }

    .img-card-body {
        padding: 16px 18px 18px;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .file-box {
        background: #f8fafd;
        border: 1px solid #dde3ee;
        border-radius: 10px;
        padding: 12px;
    }

    .img-preview {
        width: 100%;
        min-height: 320px;
        aspect-ratio: 4/3;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f8fafd;
        border: 1px dashed #d7deea;
        border-radius: 12px;
        overflow: hidden;
    }

        .img-preview img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .img-empty {
        text-align: center;
        color: #b0b8c8;
        font-size: 13px;
        padding: 20px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

        .img-empty i {
            font-size: 3.3rem;
            display: block;
            margin-bottom: 10px;
            opacity: .25;
        }

    .img-actual {
        display: flex;
        align-items: center;
        gap: 7px;
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        border-radius: 8px;
        padding: 7px 11px;
        font-size: 12px;
        color: #166534;
    }

    .form-actions {
        background: #fff;
        border: 1px solid #dde3ee;
        border-radius: 14px;
        padding: 14px 18px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        box-shadow: 0 1px 4px rgba(0,0,0,.05);
    }

    .actions-left,
    .actions-right {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .sticky-side {
        position: sticky;
        top: 18px;
    }

    @@media (max-width: 1100px) {
        .cp-layout {
            grid-template-columns: 1fr;
        }

        .sticky-side {
            position: static;
        }

        .img-preview {
            min-height: 260px;
            aspect-ratio: 16/9;
        }
    }

    @@media (max-width: 720px) {
        .field-row-3 {
            grid-template-columns: 1fr 1fr;
        }
    }

    @@media (max-width: 560px) {
        .field-row-2,
        .field-row-3 {
            grid-template-columns: 1fr;
        }

        .form-actions {
            flex-direction: column;
            align-items: stretch;
        }

        .actions-left,
        .actions-right {
            width: 100%;
            justify-content: space-between;
        }
    }
</style>

<div class="cp-page">

    @* Encabezado *@
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px">
        <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
            <div>
                <div style="font-size:22px;font-weight:700;color:#1a202c">
                    <i class="fas fa-pen me-2" style="color:#c92a2a"></i> Editar Producto
                </div>
                <div style="font-size:13px;color:#8a94a6;margin-top:3px">
                    Actualiza la información y guarda los cambios
                </div>
            </div>
            <span class="id-badge">
                <i class="fas fa-hashtag" style="font-size:10px"></i> ID: @Model.IdProducto
            </span>
        </div>

        <div style="display:flex;gap:8px;flex-wrap:wrap">
            <a asp-controller="Categorias" asp-action="Index"
               style="display:inline-flex;align-items:center;gap:7px;padding:9px 16px;border-radius:9px;background:#f4f7fc;border:1px solid #dde3ee;color:#4a5568;font-size:14px;font-weight:500;text-decoration:none"
               onmouseover="this.style.background='#fff';this.style.borderColor='#b8c4d8'"
               onmouseout="this.style.background='#f4f7fc';this.style.borderColor='#dde3ee'">
                <i class="fas fa-tags"></i> Categorías
            </a>
            <a asp-action="Index"
               style="display:inline-flex;align-items:center;gap:7px;padding:9px 16px;border-radius:9px;background:#f4f7fc;border:1px solid #dde3ee;color:#4a5568;font-size:14px;font-weight:500;text-decoration:none"
               onmouseover="this.style.background='#fff';this.style.borderColor='#b8c4d8'"
               onmouseout="this.style.background='#f4f7fc';this.style.borderColor='#dde3ee'">
                <i class="fas fa-arrow-left"></i> Volver
            </a>
        </div>
    </div>

    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input asp-for="IdProducto" type="hidden" />
        <input asp-for="ImageURL" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size:13px"></div>

        <div class="cp-layout">

            @* Columna principal *@
            <div class="left-stack">

                <div class="form-card">
                    <div class="form-card-header">
                        <div class="hdr-icon" style="background:#fff1f1">
                            <i class="fas fa-box" style="color:#c92a2a"></i>
                        </div>
                        <div>
                            <div style="font-size:13px;font-weight:700;color:#1a202c">Información básica</div>
                            <div style="font-size:11px;color:#8a94a6">Nombre y marca del repuesto</div>
                        </div>
                    </div>
                    <div class="form-card-body" style="display:flex;flex-direction:column;gap:12px">
                        <div class="field-row field-row-2">
                            <div class="field">
                                <label asp-for="Nombre">Nombre *</label>
                                <input asp-for="Nombre" />
                                <span asp-validation-for="Nombre" class="text-danger"></span>
                            </div>
                            <div class="field">
                                <label asp-for="Marca">Marca *</label>
                                <input asp-for="Marca" />
                                <span asp-validation-for="Marca" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="field">
                            <label asp-for="Descripcion">Descripción (opcional)</label>
                            <textarea asp-for="Descripcion" rows="3" placeholder="Describe el producto..."></textarea>
                            <span asp-validation-for="Descripcion" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="form-card">
                    <div class="form-card-header">
                        <div class="hdr-icon" style="background:#eff6ff">
                            <i class="fas fa-dollar-sign" style="color:#1971c2"></i>
                        </div>
                        <div>
                            <div style="font-size:13px;font-weight:700;color:#1a202c">Precios y stock</div>
                            <div style="font-size:11px;color:#8a94a6">Precio de venta calculado automáticamente</div>
                        </div>
                    </div>
                    <div class="form-card-body" style="display:flex;flex-direction:column;gap:12px">
                        <div class="field-row field-row-3">
                            <div class="field">
                                <label asp-for="PrecioCosto">Costo</label>
                                <input asp-for="PrecioCosto" id="PrecioCosto" type="text" inputmode="numeric" asp-format="{0:0}" />
                                <span asp-validation-for="PrecioCosto" class="text-danger"></span>
                            </div>
                            <div class="field">
                                <label asp-for="MargenPorcentaje">Margen (%)</label>
                                <input asp-for="MargenPorcentaje" id="MargenPorcentaje" type="text" inputmode="decimal" placeholder="Ej: 30" />
                                <div class="hint"><i class="fas fa-calculator me-1"></i>Auto</div>
                                <span asp-validation-for="MargenPorcentaje" class="text-danger"></span>
                            </div>
                            <div class="field">
                                <label asp-for="PrecioVenta">Precio venta *</label>
                                <input asp-for="PrecioVenta" id="PrecioVenta" type="text" inputmode="numeric" asp-format="{0:0}" />
                                <span asp-validation-for="PrecioVenta" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="field-row field-row-2">
                            <div class="field">
                                <label asp-for="StockActual">Stock *</label>
                                <input asp-for="StockActual" inputmode="numeric" />
                                <span asp-validation-for="StockActual" class="text-danger"></span>
                            </div>
                            <div class="field">
                                <label asp-for="CodigoBarras">Código de barras</label>
                                <input asp-for="CodigoBarras" />
                                <span asp-validation-for="CodigoBarras" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-card">
                    <div class="form-card-header">
                        <div class="hdr-icon" style="background:#f0fdf4">
                            <i class="fas fa-layer-group" style="color:#166534"></i>
                        </div>
                        <div>
                            <div style="font-size:13px;font-weight:700;color:#1a202c">Categoría</div>
                            <div style="font-size:11px;color:#8a94a6">Puedes cambiar la categoría del producto</div>
                        </div>
                    </div>
                    <div class="form-card-body">
                        <div class="field">
                            <label asp-for="IdCategoria">Categoría actual</label>
                            <div style="display:flex;gap:8px;align-items:center">
                                <select asp-for="IdCategoria"
                                        asp-items="(IEnumerable<SelectListItem>)ViewBag.Categorias"
                                        style="flex:1;background:#f8fafd;border:1px solid #dde3ee;border-radius:9px;color:#1a202c;font-size:14px;padding:10px 12px">
                                    <option value="">— Seleccione —</option>
                                </select>
                                <a asp-controller="Categorias" asp-action="Index"
                                   style="display:inline-flex;align-items:center;justify-content:center;width:38px;height:38px;border-radius:9px;background:#f4f7fc;border:1px solid #dde3ee;color:#4a5568;text-decoration:none;flex-shrink:0"
                                   title="Administrar categorías">
                                    <i class="fas fa-cog" style="font-size:13px"></i>
                                </a>
                            </div>
                            <span asp-validation-for="IdCategoria" class="text-danger" style="font-size:11px"></span>
                        </div>
                    </div>
                </div>

                <div class="form-actions">
                    <div class="actions-left">
                        <a asp-action="Index"
                           style="display:inline-flex;align-items:center;gap:7px;padding:9px 20px;border-radius:9px;background:#f4f7fc;border:1px solid #dde3ee;color:#4a5568;font-size:14px;font-weight:500;text-decoration:none">
                            <i class="fas fa-times"></i> Cancelar
                        </a>
                    </div>
                    <div class="actions-right">
                        <button type="submit"
                                style="display:inline-flex;align-items:center;gap:7px;padding:10px 30px;border-radius:9px;background:#c92a2a;border:none;color:#fff;font-size:14px;font-weight:600;cursor:pointer"
                                onmouseover="this.style.background='#a61e1e'"
                                onmouseout="this.style.background='#c92a2a'">
                            <i class="fas fa-save"></i> Guardar cambios
                        </button>
                    </div>
                </div>

            </div>

            @* Columna secundaria *@
            <div class="right-stack sticky-side">

                <div class="tips-panel">
                    <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px">
                        <i class="fas fa-lightbulb" style="color:rgba(255,255,255,.82);font-size:14px"></i>
                        <span style="font-size:13px;font-weight:700;color:#fff">Tips para editar</span>
                    </div>
                    <div class="tip-row"><i class="fas fa-lock-open"></i><span>Solo los campos que modifiques serán <strong>actualizados</strong>.</span></div>
                    <div class="tip-row"><i class="fas fa-calculator"></i><span>Cambia el <strong>costo o margen</strong> para recalcular el precio.</span></div>
                    <div class="tip-row"><i class="fas fa-image"></i><span>Sin nueva imagen, se <strong>conserva la actual</strong> automáticamente.</span></div>
                </div>

                <div class="img-card">
                    <div class="form-card-header">
                        <div class="hdr-icon" style="background:#fdf4ff">
                            <i class="fas fa-image" style="color:#7c3aed"></i>
                        </div>
                        <div>
                            <div style="font-size:13px;font-weight:700;color:#1a202c">Imagen del producto</div>
                            <div style="font-size:11px;color:#8a94a6">
                                @(tieneImagen ? "Sube una nueva para reemplazar la actual" : "Opcional — JPG, PNG, WEBP")
                            </div>
                        </div>
                    </div>

                    <div class="img-card-body">
                        @if (tieneImagen)
                        {
                            <div class="img-actual">
                                <i class="fas fa-check-circle"></i>
                                <span>Este producto ya tiene imagen.</span>
                            </div>
                        }

                        <div class="file-box">
                            <input name="imagen" id="imagenInput" type="file" accept="image/*"
                                   style="background:#f8fafd;border:1px solid #dde3ee;border-radius:9px;color:#1a202c;font-size:13px;padding:9px 12px;width:100%" />
                        </div>

                        <div class="img-preview">
                            <img id="previewImg" alt="preview"
                                 src="@(tieneImagen? Model.ImageURL: "")"
                                 style="display:@(tieneImagen ? "block" : "none")" />
                            <div id="previewEmpty" class="img-empty"
                                 style="display:@(tieneImagen ? "none" : "flex")">
                                <i class="fas fa-image"></i>
                                <div style="font-weight:600;color:#8a94a6;margin-bottom:2px">Vista previa</div>
                                <div>La imagen del producto aparecerá aquí</div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const input = document.getElementById('imagenInput');
            const img = document.getElementById('previewImg');
            const empty = document.getElementById('previewEmpty');

            if (input) {
                input.addEventListener('change', () => {
                    const file = input.files?.[0];
                    if (!file || !file.type.startsWith('image/')) return;

                    img.src = URL.createObjectURL(file);
                    img.style.display = 'block';
                    empty.style.display = 'none';
                });
            }

            const costoEl = document.getElementById("PrecioCosto"),
                  margenEl = document.getElementById("MargenPorcentaje"),
                  ventaEl = document.getElementById("PrecioVenta");

            if (!costoEl || !margenEl || !ventaEl) return;

            let lock = false;

            const toNum = v => parseFloat((v ?? "").toString().trim().replace(/\s/g, "").replace(",", "."));
            const setInt = (el, n) => {
                if (el) el.value = isFinite(n) ? Math.round(n).toString() : "";
            };

            const calcVenta = () => {
                if (lock) return;
                lock = true;

                const c = toNum(costoEl.value), m = toNum(margenEl.value);
                if (isFinite(c) && isFinite(m) && c >= 0 && m >= 0) {
                    setInt(ventaEl, c * (1 + m / 100));
                }

                lock = false;
            };

            const calcMargen = () => {
                if (lock) return;
                lock = true;

                const c = toNum(costoEl.value), v = toNum(ventaEl.value);
                if (isFinite(c) && isFinite(v) && c > 0 && v >= 0) {
                    margenEl.value = isFinite(((v / c) - 1) * 100)
                        ? (((v / c) - 1) * 100).toFixed(2).replace(".", ",")
                        : "";
                }

                lock = false;
            };

            costoEl.addEventListener("input", () => isFinite(toNum(margenEl.value)) ? calcVenta() : calcMargen());
            margenEl.addEventListener("input", calcVenta);
            ventaEl.addEventListener("input", calcMargen);

            const ci = toNum(costoEl.value),
                  vi = toNum(ventaEl.value),
                  mi = toNum(margenEl.value);

            if (!isFinite(mi) && isFinite(ci) && isFinite(vi) && ci > 0) {
                calcMargen();
            }
        });
    </script>
}