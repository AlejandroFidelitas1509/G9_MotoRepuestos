        }

    .cp-preview-label {
        font-weight: 800;
        color: #111;
        margin-bottom: 6px;
    }

    .cp-preview-box {
        border: 1px dashed rgba(0,0,0,.18);
        border-radius: 16px;
        height: 210px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0,0,0,.02);
        overflow: hidden;
    }

    #previewImg {
        width: 100%;
