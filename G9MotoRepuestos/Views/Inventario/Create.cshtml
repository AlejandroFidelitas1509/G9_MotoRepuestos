@using MR.Abstracciones.EntidadesParaUI
@model ProductoDto

@{
    ViewData["Title"] = "Crear Producto";
}

<link rel="stylesheet" href="~/css/Home/Catalogo.css" asp-append-version="true" />

<div class="cp-wrap">

    <!-- Header -->
    <div class="cp-hero rounded-4 shadow-sm p-4 mb-4">
        <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
            <div>
                <div class="cp-kicker">Inventario</div>
                <h1 class="cp-title m-0">Crear Producto</h1>
                <div class="cp-sub mt-2">Completa la información y guarda el producto en el inventario.</div>
            </div>

            <div class="d-flex gap-2 flex-wrap">
                <a asp-action="Index" class="btn btn-outline-dark cp-btn">
                    ← Volver al inventario
                </a>
                <a asp-controller="Categorias" asp-action="Index" class="btn btn-dark cp-btn">
                    Categorías
                </a>
            </div>
        </div>
    </div>

    <!-- Form Card -->
    <div class="card border-0 rounded-4 shadow-sm overflow-hidden">
        <div class="cp-card-header p-3 px-4">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                <div class="fw-bold text-white">Datos del producto</div>
                <div class="cp-header-hint">Campos obligatorios marcados con *</div>
            </div>
        </div>

        <div class="card-body p-4">
            <form asp-action="Create" method="post" enctype="multipart/form-data" class="cp-form">
                @Html.AntiForgeryToken()

                <!-- Resumen de validación -->
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-4">
                    <!-- Columna izquierda -->
                    <div class="col-12 col-lg-7">
                        <div class="cp-section mb-4">
                            <div class="cp-section-title">Información básica</div>
                            <div class="cp-section-sub">Nombre y marca para identificar el repuesto.</div>

                            <div class="row g-3 mt-1">
                                <div class="col-12">
                                    <label asp-for="Nombre" class="form-label cp-label">Nombre *</label>
                                    <input asp-for="Nombre" class="form-control cp-input" placeholder="Ej: Aceite 10W-40" />
                                    <span asp-validation-for="Nombre" class="text-danger"></span>
                                </div>

                                <div class="col-12">
                                    <label asp-for="Marca" class="form-label cp-label">Marca *</label>
                                    <input asp-for="Marca" class="form-control cp-input" placeholder="Ej: Motul, Castrol..." />
                                    <span asp-validation-for="Marca" class="text-danger"></span>
                                </div>

                                <div class="col-12">
                                    <label asp-for="Descripcion" class="form-label cp-label">Descripción (opcional)</label>
                                    <textarea asp-for="Descripcion" class="form-control cp-input" rows="3" placeholder="Describe el producto..."></textarea>
                                    <span asp-validation-for="Descripcion" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="cp-section">
                            <div class="cp-section-title">Precios y stock</div>
                            <div class="cp-section-sub">Define el costo, margen y el precio de venta automáticamente.</div>

                            <div class="row g-3 mt-1">
                                <div class="col-12 col-md-4">
                                    <label asp-for="PrecioCosto" class="form-label cp-label">Precio costo (opcional)</label>
                                    <input asp-for="PrecioCosto" id="PrecioCosto" class="form-control cp-input" placeholder="₡0" inputmode="decimal" />
                                    <span asp-validation-for="PrecioCosto" class="text-danger"></span>
                                </div>

                                <div class="col-12 col-md-4">
                                    <label asp-for="MargenPorcentaje" class="form-label cp-label">Margen (%)</label>
                                    <input asp-for="MargenPorcentaje" id="MargenPorcentaje" class="form-control cp-input" placeholder="Ej: 30" inputmode="decimal" />
                                    <span asp-validation-for="MargenPorcentaje" class="text-danger"></span>
                                </div>

                                <div class="col-12 col-md-4">
                                    <label asp-for="PrecioVenta" class="form-label cp-label">Precio venta *</label>
                                    <input asp-for="PrecioVenta" id="PrecioVenta" class="form-control cp-input" placeholder="₡0" inputmode="decimal" />
                                    <span asp-validation-for="PrecioVenta" class="text-danger"></span>
                                </div>

                                <div class="col-12 col-md-4">
                                    <label asp-for="StockActual" class="form-label cp-label">Stock inicial *</label>
                                    <input asp-for="StockActual" class="form-control cp-input" placeholder="0" inputmode="numeric" />
                                    <span asp-validation-for="StockActual" class="text-danger"></span>
                                </div>

                                <div class="col-12 col-md-8">
                                    <label asp-for="CodigoBarras" class="form-label cp-label">Código de barras (opcional)</label>
                                    <input asp-for="CodigoBarras" class="form-control cp-input" placeholder="Ej: 7501031311309" />
                                    <span asp-validation-for="CodigoBarras" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Columna derecha -->
                    <div class="col-12 col-lg-5">
                        <div class="cp-side card border-0 rounded-4 p-3 shadow-sm">
                            <div class="cp-side-title">Categoría e imagen</div>
                            <div class="cp-side-sub">Organiza y agrega una foto para el catálogo.</div>

                            <div class="mt-3">
                                <label asp-for="IdCategoria" class="form-label cp-label">Categoría</label>

                                <div class="d-flex gap-2">
                                    <select asp-for="IdCategoria"
                                            class="form-select cp-input"
                                            asp-items="(IEnumerable<SelectListItem>)ViewBag.Categorias">
                                        <option value="">-- Seleccione --</option>
                                    </select>

                                    <a asp-controller="Categorias" asp-action="Create" class="btn btn-dark cp-btn-sm">
                                        Nueva
                                    </a>
                                </div>

                                <div class="mt-2">
                                    <a asp-controller="Categorias" asp-action="Index" class="cp-link">
                                        Administrar categorías →
                                    </a>
                                </div>

                                <span asp-validation-for="IdCategoria" class="text-danger"></span>
                            </div>

                            <hr class="cp-hr" />

                            <div>
                                <label class="form-label cp-label">Imagen (opcional)</label>

                                <input name="imagen" id="imagenInput" type="file" class="form-control cp-input" accept="image/*" />

                                <div class="cp-preview mt-3">
                                    <div class="cp-preview-label">Vista previa</div>
                                    <div class="cp-preview-box">
                                        <img id="previewImg" alt="preview" style="display:none;" />
                                        <div id="previewEmpty" class="cp-preview-empty">
                                            Sin imagen
                                        </div>
                                    </div>
                                    <div class="cp-preview-hint">Se guardará en <strong>/wwwroot/images/productos</strong></div>
                                </div>
                            </div>
                        </div>

                        <div class="cp-tips mt-3">
                            <div class="cp-tip">
                                <div class="cp-tip-title">Tip rápido</div>
                                <div class="cp-tip-text">
                                    Si la categoría no existe, crea una nueva y vuelve a seleccionar.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Footer buttons -->
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mt-4">
                    <a asp-action="Index" class="btn btn-dark cp-btn">
                        Cancelar
                    </a>

                    <button type="submit" class="btn btn-danger cp-btn">
                        Guardar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener("DOMContentLoaded", () => {

            // =========================
            // PREVIEW IMAGEN
            // =========================
            const input = document.getElementById('imagenInput');
            const img = document.getElementById('previewImg');
            const empty = document.getElementById('previewEmpty');

            if (input) {
                input.addEventListener('change', () => {
                    const file = input.files && input.files[0];

                    if (!file || !file.type.startsWith('image/')) {
                        if (img) img.style.display = 'none';
                        if (empty) empty.style.display = 'flex';
                        if (img) img.src = '';
                        return;
                    }

                    const url = URL.createObjectURL(file);
                    if (img) {
                        img.src = url;
                        img.style.display = 'block';
                    }
                    if (empty) empty.style.display = 'none';
                });
            }

            // =========================
            // AUTO CÁLCULO PRECIOS
            // =========================
            const costoEl = document.getElementById("PrecioCosto");
            const margenEl = document.getElementById("MargenPorcentaje");
            const ventaEl = document.getElementById("PrecioVenta");

            if (!costoEl || !margenEl || !ventaEl) return;

            let lock = false;

            const toNumber = (v) => {
                if (v === null || v === undefined) return NaN;
                v = v.toString().trim();
                if (!v) return NaN;

                // soporta coma o punto
                v = v.replace(/\s/g, "").replace(",", ".");
                return parseFloat(v);
            };

            const setValue = (el, num, decimals = 2) => {
                if (!el) return;
                el.value = Number.isFinite(num) ? num.toFixed(decimals) : "";
            };

            const calcVenta = () => {
                if (lock) return;
                lock = true;

                const costo = toNumber(costoEl.value);
                const margen = toNumber(margenEl.value);

                if (Number.isFinite(costo) && Number.isFinite(margen) && costo >= 0 && margen >= 0) {
                    const venta = costo * (1 + (margen / 100));
                    setValue(ventaEl, venta, 2);
                }

                lock = false;
            };

            const calcMargen = () => {
                if (lock) return;
                lock = true;

                const costo = toNumber(costoEl.value);
                const venta = toNumber(ventaEl.value);

                if (Number.isFinite(costo) && Number.isFinite(venta) && costo > 0 && venta >= 0) {
                    const margen = ((venta / costo) - 1) * 100;
                    setValue(margenEl, margen, 2);
                }

                lock = false;
            };

            // Eventos
            costoEl.addEventListener("input", () => {
                const margen = toNumber(margenEl.value);
                if (Number.isFinite(margen)) calcVenta();
                else calcMargen();
            });

            margenEl.addEventListener("input", calcVenta);
            ventaEl.addEventListener("input", calcMargen);

            // Auto completar margen al abrir (modo Edit)
            const costoIni = toNumber(costoEl.value);
            const ventaIni = toNumber(ventaEl.value);
            const margenIni = toNumber(margenEl.value);

            if (!Number.isFinite(margenIni) && Number.isFinite(costoIni) && Number.isFinite(ventaIni) && costoIni > 0) {
                calcMargen();
            }

        });
    </script>
}
}

<style>
    /* Paleta: rojo/negro como tu sitio */
    .cp-wrap {
        padding-bottom: 24px;
    }

    .cp-hero {
        background: linear-gradient(180deg, #ffffff 0%, #fbfbfb 100%);
