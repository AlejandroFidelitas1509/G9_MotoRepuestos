@{
    ViewData["Title"] = "Panel de Control";
}

<link rel="stylesheet" href="~/css/Panel.css" asp-append-version="true" />

<div class="container my-5 py-4 fade-in">

    <div class="mb-5">
        <h2 class="fw-bold text-uppercase section-title">
            PANEL DE CONTROL <i class="fas fa-tachometer-alt text-danger ms-2"></i>
        </h2>
        <p class="text-muted">Bienvenido, <span class="fw-bold text-dark">@User.Identity?.Name</span>. Resumen administrativo .</p>
        <hr class="border-danger opacity-100" style="width: 60px; height: 4px; border-radius: 2px;">
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card kpi-card border-0 shadow-sm rounded-4 p-3 text-center bg-white h-100">
                <div class="text-danger mb-2"><i class="fas fa-boxes fa-2x"></i></div>
                <h6 class="text-muted small text-uppercase fw-bold">Productos</h6>
                <h3 class="fw-bold mb-0">124</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card kpi-card border-0 shadow-sm rounded-4 p-3 text-center bg-white h-100">
                <div class="text-danger mb-2"><i class="fas fa-users fa-2x"></i></div>
                <h6 class="text-muted small text-uppercase fw-bold">Usuarios</h6>
                <h3 class="fw-bold mb-0">45</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card kpi-card border-0 shadow-sm rounded-4 p-3 text-center bg-white h-100">
                <div class="text-danger mb-2"><i class="fas fa-cash-register fa-2x"></i></div>
                <h6 class="text-muted small text-uppercase fw-bold">Ventas Hoy</h6>

                <h3 class="fw-bold mb-1 text-danger">@ViewBag.VentasHoyCantidad</h3>
                <small class="text-muted d-block">Cantidad de ventas</small>

                <hr class="my-2" />

                <h5 class="fw-bold mb-0 text-dark">₡ @(((decimal)ViewBag.VentasHoyMonto).ToString("N2"))</h5>
                <small class="text-muted d-block">Monto total vendido</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card kpi-card border-0 shadow-sm rounded-4 p-3 text-center bg-white h-100">
                <div class="text-danger mb-2"><i class="fas fa-calendar-check fa-2x"></i></div>
                <h6 class="text-muted small text-uppercase fw-bold">Citas</h6>
                <h3 class="fw-bold mb-0">8</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card kpi-card border-0 shadow-sm rounded-4 p-3 text-center bg-white h-100">
                <div class="text-danger mb-2"><i class="fas fa-calendar-check fa-2x"></i></div>
                <h6 class="text-muted small text-uppercase fw-bold">Servicios</h6>
                <h3 class="fw-bold mb-0">8</h3>
            </div>
        </div>
    </div>

    <div class="p-4 p-md-5 bg-dark rounded-4 shadow-lg">
        <h5 class="text-white fw-bold mb-4 border-bottom border-secondary pb-2">
            <i class="fas fa-th-large me-2 text-danger"></i>GESTIÓN DEL NEGOCIO
        </h5>

        <div class="row g-4">
            <div class="col-6 col-md-3">
                <a asp-controller="Usuarios" asp-action="GestionUsuarios" class="module-link">
                    <i class="fas fa-user-cog mb-2"></i>
                    <span>USUARIOS</span>
                </a>
            </div>
            <div class="col-6 col-md-3">
                <a asp-controller="Inventario" asp-action="Index" class="module-link">
                    <i class="fas fa-tools mb-2"></i>
                    <span>INVENTARIO</span>
                </a>
            </div>
            <div class="col-6 col-md-3">
                <a asp-controller="PuntoVenta" asp-action="Index" class="module-link">
                    <i class="fas fa-shopping-cart mb-2"></i>
                    <span>CAJA (POS)</span>
                </a>
            </div>
            <div class="col-6 col-md-3">
                <a asp-controller="Citas" asp-action="Index" class="module-link">
                    <i class="fas fa-calendar-alt mb-2"></i>
                    <span>CITAS TALLER</span>
                </a>
            </div>
            <div class="col-6 col-md-3">
                <a asp-controller="Contabilidad" asp-action="Index" class="module-link">
                    <i class="fas fa-file-invoice-dollar mb-2"></i>
                    <span>FINANZAS</span>
                </a>
            </div>
            <div class="col-6 col-md-3">
                <a asp-controller="Servicios" asp-action="GestionServicios" class="module-link">
                    <i class="fas fa-motorcycle mb-2"></i>
                    <span>SERVICIOS</span>
                </a>
            </div>
            <div class="col-6 col-md-3">
                <a asp-controller="Reportes" asp-action="Index" class="module-link">
                    <i class="fas fa-chart-bar mb-2"></i>
                    <span>REPORTES</span>
                </a>
            </div>
            <div class="col-6 col-md-3">
                <a asp-controller="Home" asp-action="Index" class="module-link btn-tienda">
                    <i class="fas fa-external-link-alt mb-2"></i>
                    <span>IR A TIENDA</span>
                </a>
            </div>
        </div>
    </div>
    
</div>