@{
    ViewData["Title"] = "Inicio";
}

<link rel="stylesheet" href="~/css/Index.css" asp-append-version="true" />

<div id="heroCarousel" class="carousel slide mb-5" data-bs-ride="carousel">
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active"></button>
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1"></button>
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2"></button>
    </div>

    <div class="carousel-inner">
        <div class="carousel-item active">
            <div class="d-flex align-items-center w-100" style="height: 60vh; min-height: 450px; background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('/images/banner1.jpg') center/cover;">
                <div class="container">
                    <div class="row align-items-center">
                        <div class="col-md-6 text-center text-md-start">
                            <h1 class="display-4 fw-bold text-uppercase text-white">Pasión por las dos ruedas</h1>
                            <p class="lead text-white d-none d-md-block">Encuentra los mejores repuestos y accesorios.</p>
                            <a href="#" class="btn btn-lg rounded-0 mt-3 text-white fw-bold shadow-sm" style="background-color: var(--primary-red); border: none;">VER CATÁLOGO</a>
                        </div>
                        <div class="col-md-6 d-none d-md-block text-center">
                            <img src="/images/repuestos-promo.png" alt="Repuestos" class="img-fluid" style="max-height: 350px; filter: drop-shadow(0 10px 15px rgba(0,0,0,0.5));">
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="carousel-item">
            <div class="d-flex align-items-center w-100" style="height: 60vh; min-height: 450px; background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('/images/banner2.jpg') center/cover;">
                <div class="container">
                    <div class="row align-items-center">
                        <div class="col-md-6 text-center text-md-start">
                            <h1 class="display-4 fw-bold text-uppercase text-white">Taller Mecánico</h1>
                            <p class="lead text-white d-none d-md-block">Mantenimiento General y Preventivo con expertos.</p>
                            <a href="#" class="btn btn-lg rounded-0 mt-3 text-white fw-bold shadow-sm" style="background-color: var(--primary-red); border: none;">AGENDAR CITA</a>
                        </div>
                        <div class="col-md-6 d-none d-md-block text-center">
                            <img src="/images/herramientas-taller.png" alt="Taller" class="img-fluid" style="max-height: 350px; filter: drop-shadow(0 10px 15px rgba(0,0,0,0.5));">
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="carousel-item">
            <div class="d-flex align-items-center w-100" style="height: 60vh; min-height: 450px; background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('/images/banner3.jpg') center/cover;">
                <div class="container">
                    <div class="row align-items-center">
                        <div class="col-md-6 text-center text-md-start fade-in">
                            <h1 class="display-4 fw-bold text-uppercase text-white">Nuevos Cascos FTS</h1>
                            <p class="lead text-white">Protección y estilo aerodinámico.</p>
                            <a href="#" class="btn btn-lg text-white fw-bold" style="background-color: var(--rojo-rojas); border-radius:0;">VER COLECCIÓN</a>
                        </div>
                        <div class="col-md-6 d-none d-md-flex justify-content-center align-items-center">
                            <img src="/images/casco-fts.png" class="img-producto-carousel" alt="Casco FTS">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Anterior</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Siguiente</span>
    </button>
</div>






<div class="container mt-5 mb-5">
    <div class="d-flex align-items-center mb-4">
        <div style="width: 5px; height: 35px; background-color: var(--primary-red); margin-right: 15px;"></div>
        <h2 class="m-0 text-uppercase">Novedades</h2>
    </div>
    <div class="row">
        <div class="col-6 col-md-4 col-lg-3 mb-4">
            <div class="card h-100 product-card border-0 shadow-sm position-relative">
                <span class="badge position-absolute top-0 start-0 m-2 px-3 py-2" style="background-color: var(--primary-red); z-index: 1;">NUEVO</span>
                <div class="p-3 text-center">
                    <img src="/images/casco_ejemplo.jpg" class="img-fluid" alt="Casco" style="height: 180px; object-fit: contain;">
                </div>
                <div class="card-body d-flex flex-column">
                    <small class="text-muted text-uppercase">Cascos</small>
                    <h6 class="card-title fw-bold">Casco LS2 Rapid Dead</h6>
                    <p class="h5 fw-bold mt-auto" style="color: var(--primary-red);">₡68,000</p>
                    <a href="#" class="btn btn-outline-dark btn-sm mt-2 rounded-0">VER MÁS</a>
                </div>
            </div>
        </div>
    </div>
</div>

