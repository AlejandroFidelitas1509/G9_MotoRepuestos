@using MR.Abstracciones.EntidadesParaUI
@model IEnumerable<BloqueosCalendarioDto>

@{
    ViewData["Title"] = "Bloqueos de Citas";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Bloqueos de Citas</h2>

    <button class="btn btn-danger"
            data-bs-toggle="modal"
            data-bs-target="#modalNuevoBloqueo">
        + Nuevo bloqueo
    </button>
</div>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Fecha Inicio</th>
            <th>Fecha Fin</th>
            <th>Motivo</th>
            <th>Activo</th>
            <th>Editar</th>
            <th>Eliminar</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.IdBloqueo</td>
                <td>@item.FechaInicio</td>
                <td>@item.FechaFin</td>
                <td>@item.Motivo</td>
                <td>
                    @(item.Activo ? "Sí" : "No")
                </td>

                <td>
                    <a asp-action="Edit"
                       asp-route-id="@item.IdBloqueo"
                       class="btn btn-warning btn-sm">
                        Editar
                    </a>
                </td>

                <td>
                    <a asp-action="Delete"
                       asp-route-id="@item.IdBloqueo"
                       class="btn btn-danger btn-sm">
                        Eliminar
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>


<!-- MODAL NUEVO BLOQUEO -->

<div class="modal fade"
     id="modalNuevoBloqueo"
     tabindex="-1"
     aria-labelledby="modalNuevoBloqueoLabel"
     aria-hidden="true">

    <div class="modal-dialog modal-dialog-centered">

        <div class="modal-content">

            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="modalNuevoBloqueoLabel">
                    Nuevo Bloqueo de Citas
                </h5>

                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal">
                </button>
            </div>


            <form asp-action="Create" method="post">

                <div class="modal-body">

                    <div class="mb-3">
                        <label class="form-label">Fecha Inicio</label>

                        <input name="FechaInicio"
                               type="datetime-local"
                               class="form-control"
                               required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Fecha Fin</label>

                        <input name="FechaFin"
                               type="datetime-local"
                               class="form-control"
                               required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Motivo</label>

                        <input name="Motivo"
                               class="form-control"
                               placeholder="Ej: Día feriado, mantenimiento..." />
                    </div>

                    <div class="form-check">
                        <input name="Activo"
                               type="checkbox"
                               class="form-check-input"
                               checked />

                        <label class="form-check-label">
                            Bloqueo activo
                        </label>
                    </div>

                </div>


                <div class="modal-footer">

                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancelar
                    </button>

                    <button type="submit"
                            class="btn btn-danger">
                        Guardar
                    </button>

                </div>

            </form>

        </div>
    </div>
</div>