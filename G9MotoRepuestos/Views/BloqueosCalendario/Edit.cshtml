@using MR.Abstracciones.EntidadesParaUI
@model BloqueosCalendarioDto

@{
    ViewData["Title"] = "Editar Bloqueo";
}

<h2>Editar Bloqueo</h2>

<form asp-action="Edit">

    <input type="hidden" asp-for="IdBloqueo" />

    <div class="form-group">
        <label>Fecha Inicio</label>
        <input asp-for="FechaInicio" type="datetime-local" class="form-control" />
    </div>

    <div class="form-group">
        <label>Fecha Fin</label>
        <input asp-for="FechaFin" type="datetime-local" class="form-control" />
    </div>

    <div class="form-group">
        <label>Motivo</label>
        <input asp-for="Motivo" class="form-control" />
    </div>

    <div class="form-group">
        <label>Activo</label>
        <input asp-for="Activo" type="checkbox" />
    </div>

    <br />

    <button type="submit" class="btn btn-success">Guardar</button>

    <a asp-action="Index" class="btn btn-secondary">Volver</a>

</form>