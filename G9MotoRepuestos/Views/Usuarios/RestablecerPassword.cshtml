<link rel="stylesheet" href="~/css/Sesion/Login.css" asp-append-version="true" />
@{
    ViewData["Title"] = "Nueva Contraseña - Moto Repuestos Rojas";
}

<div class="auth-wrapper shadow-lg">
    <div class="col-md-5 col-lg-4 px-3">
        <div class="card glass-card border-0 rounded-4 shadow-lg">
            <div class="card-body p-4 p-md-5">

                <div class="text-center mb-4">
                    <div class="bg-white d-inline-block p-3 rounded-circle mb-3 shadow">
                        <i class="fas fa-lock-open fa-2x text-danger"></i>
                    </div>
                    <h2 class="fw-bold text-white">Nueva Clave</h2>
                    <p class="text-light-muted small">Escribe tu nueva contraseña de acceso</p>
                </div>

                <form asp-action="RestablecerPassword" asp-controller="Usuarios" method="post">
                    @Html.AntiForgeryToken()

                    @* Token oculto que viene desde el correo *@
                    <input type="hidden" name="token" value="@ViewBag.Token" />

                    <div class="mb-4">
                        <label class="form-label small fw-bold text-white">Nueva Contraseña</label>
                        <div class="position-relative">
                            <input type="password" name="nuevaPassword" id="passInput"
                                   class="form-control rounded-pill form-control-custom pe-5"
                                   placeholder="Mínimo 6 caracteres" required>

                            <button type="button" onclick="togglePassword()"
                                    class="btn position-absolute end-0 top-50 translate-middle-y me-2 border-0 shadow-none"
                                    style="background: none; color: #333; z-index: 10;">
                                <i id="ojoIcono" class="fas fa-eye"></i>
                            </button>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-rojas-auth text-white w-100 rounded-pill py-2 fw-bold shadow">
                        ACTUALIZAR CONTRASEÑA
                    </button>
                </form>

                <div class="text-center mt-4">
                    <a asp-action="Login" class="text-light-muted small text-decoration-none">
                        <i class="fas fa-chevron-left me-1"></i> Cancelar y volver
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function togglePassword() {
            const passInput = document.getElementById("passInput");
            const icono = document.getElementById("ojoIcono");

            if (passInput.type === "password") {
                passInput.type = "text";
                icono.classList.replace("fa-eye", "fa-eye-slash");
            } else {
                passInput.type = "password";
                icono.classList.replace("fa-eye-slash", "fa-eye");
            }
        }
    </script>
}