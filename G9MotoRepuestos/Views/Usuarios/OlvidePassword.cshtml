<link rel="stylesheet" href="~/css/Sesion/Login.css" asp-append-version="true" />
<div class="auth-wrapper shadow-lg">
    <div class="col-md-5 col-lg-4 px-3">
        <div class="card glass-card border-0 rounded-4 p-4 text-center">
            <h3 class="text-white fw-bold">Recuperar Clave</h3>
            <p class="text-light-muted small">Enviaremos un enlace a tu correo</p>

            <form asp-action="OlvidePassword" method="post">
                <div class="mb-3 text-start">
                    <label class="form-label small fw-bold text-white">Tu Correo</label>
                    <input type="email" name="correo" class="form-control rounded-pill form-control-custom" required>
                </div>
                <button type="submit" class="btn btn-rojas-auth text-white w-100 rounded-pill fw-bold">ENVIAR LINK</button>
            </form>
            <a asp-action="Login" class="text-white-50 small mt-3 d-block text-decoration-none">Volver al Login</a>
        </div>
    </div>
</div>