<link rel="stylesheet" href="~/css/Sesion/Login.css" asp-append-version="true" />
@{
    ViewData["Title"] = "Ingresar - Moto Repuestos Rojas";
}

<div class="auth-wrapper shadow-lg">
    <div class="col-md-4 col-lg-3 px-3">
        <div class="card glass-card border-0 rounded-4 shadow-lg">
            <div class="card-body p-4">
                <div class="text-center mb-3">
                    <div class="bg-white d-inline-block p-2 rounded-circle mb-2 shadow">
                        <i class="fas fa-motorcycle fa-lg text-danger"></i>
                    </div>
                    <h5 class="fw-bold text-white mb-1">Bienvenido</h5>
                    <p class="text-light-muted small mb-0">Acceso para clientes y personal</p>
                </div>

                @if (TempData["Mensaje"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show rounded-pill small py-2 mb-3" role="alert">
                        <i class="fas fa-check-circle me-2"></i> @TempData["Mensaje"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (ViewBag.Error != null || TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show rounded-pill small py-2 mb-3" role="alert">
                        <i class="fas fa-exclamation-circle me-2"></i> @(ViewBag.Error ?? TempData["Error"])
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <form asp-action="Login" asp-controller="Usuarios" method="post">
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-white mb-1">Correo Electrónico</label>
                        <input type="email" name="correo" class="form-control rounded-pill form-control-custom"
                               placeholder="ejemplo@rojas.com" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-white mb-1">Contraseña</label>
                        <div class="position-relative">
                            <input type="password" id="passInput" name="password"
                                   class="form-control rounded-pill form-control-custom pe-5"
                                   placeholder="••••••••" required>
                            <button type="button" onclick="togglePassword()"
                                    class="btn position-absolute end-0 top-50 translate-middle-y me-2 border-0 shadow-none"
                                    style="background:none;color:#333;z-index:10">
                                <i id="ojoIcono" class="fas fa-eye"></i>
                            </button>
                        </div>
                    </div>

                    <div class="text-end mb-3">
                        <a asp-action="OlvidePassword" class="text-white-50 small text-decoration-none">
                            ¿Olvidaste tu contraseña?
                        </a>
                    </div>

                    <button type="submit" class="btn btn-rojas-auth text-white w-100 rounded-pill py-2 fw-bold shadow">
                        INGRESAR
                    </button>
                </form>

                <div class="text-center mt-3 border-top border-light pt-3">
                    <p class="small text-white mb-1">¿No tienes cuenta aún?</p>
                    <a asp-action="Registro" class="text-warning fw-bold text-decoration-none small">
                        Regístrate aquí
                    </a>
                </div>

                <div class="text-center mt-2">
                    <a asp-controller="Home" asp-action="Index" class="text-light-muted small text-decoration-none">
                        <i class="fas fa-arrow-left me-1"></i> Volver al Inicio
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function togglePassword() {
            const passInput = document.getElementById("passInput");
            const icono     = document.getElementById("ojoIcono");
            if (passInput.type === "password") {
                passInput.type = "text";
                icono.classList.replace("fa-eye", "fa-eye-slash");
            } else {
                passInput.type = "password";
                icono.classList.replace("fa-eye-slash", "fa-eye");
            }
        }
    </script>
}
