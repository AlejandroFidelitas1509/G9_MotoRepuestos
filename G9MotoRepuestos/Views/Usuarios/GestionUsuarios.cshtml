@model IEnumerable<G9MotoRepuestos.Models.Usuario>
@{
    ViewData["Title"] = "Gestión de Usuarios | Moto Repuestos Rojas";
}

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
<link rel="stylesheet" href="~/css/Usuarios/GestionUsuarios.css" asp-append-version="true" />

<div class="container mt-5 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="titulo-modulo m-0">Gestión de Usuarios</h2>
        <a asp-action="CrearUsuario" class="btn-rojo px-4 py-2 text-decoration-none">
            <i class="fas fa-plus me-2"></i>NUEVO USUARIO
        </a>
    </div>

    <div class="panel-modulo p-4">
        <table id="tablaUsuarios" class="table table-hover w-100">
            <thead>
                <tr>
                    <th>Nombre Completo</th>
                    <th>Correo Electrónico</th>
                    <th class="text-center">Rol</th>
                    <th class="text-center">Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    bool estaActivo = item.Estado ?? false;
                    bool esAdmin = item.Rol?.Tipo == "Admin" || item.Rol?.Tipo == "Administrador";

                    <tr>
                        <td class="align-middle">
                            <span class="fw-bold @(estaActivo ? "" : "text-muted") text-uppercase">@item.NombreCompleto</span>
                        </td>
                        <td class="align-middle text-muted small">@item.Correo</td>
                        <td class="align-middle text-center">
                            <span class="badge @(esAdmin ? "bg-danger" : "bg-dark")">
                                @(item.Rol?.Tipo ?? "Cliente")
                            </span>
                        </td>
                        <td class="align-middle text-center">
                            <span class="badge @(estaActivo ? "bg-success" : "bg-dark")">
                                @(estaActivo ? "Activo" : "Bloqueado")
                            </span>
                        </td>
                        <td class="text-center align-middle">
                            <div class="btn-group">
                                <a asp-action="EditarUsuario" asp-route-id="@item.IdUsuario" class="btn btn-sm btn-dark rounded-0 me-1">
                                    <i class="fas fa-edit"></i>
                                </a>
                                @if (!esAdmin)
                                {
                                    <form asp-action="CambiarEstado" asp-route-id="@item.IdUsuario" method="post" class="d-inline ms-1">
                                        @Html.AntiForgeryToken()
                                        <button type="button" class="btn btn-sm btn-outline-danger rounded-0 btn-cambiar-estado"
                                                data-nombre="@item.NombreCompleto"
                                                data-accion="@(estaActivo ? "BLOQUEAR" : "ACTIVAR")">
                                            <i class="fas @(estaActivo ? "fa-ban" : "fa-check-circle")"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>



@section Scripts {
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            $('#tablaUsuarios').DataTable({
                "language": { "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json" },
                "pageLength": 10,
                "responsive": true,
                "columnDefs": [{ "orderable": false, "targets": 4 }]
            });

            $(".btn-cambiar-estado").on("click", function () {
                var btn = $(this);
                Swal.fire({
                    title: '¿Confirmar acción?',
                    text: "¿Deseas " + btn.data("accion").toLowerCase() + " al usuario: " + btn.data("nombre") + "?",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#B01E1E',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Confirmar'
                }).then((result) => { if (result.isConfirmed) btn.closest("form").submit(); });
            });

            @if (TempData["Mensaje"] != null)
            {
                    <text>
                    Swal.fire({ icon: 'success', title: '¡Listo!', text: '@TempData["Mensaje"]', timer: 2500, showConfirmButton: false });
                    </text>
            }
        });
    </script>
}
        
        
        
        