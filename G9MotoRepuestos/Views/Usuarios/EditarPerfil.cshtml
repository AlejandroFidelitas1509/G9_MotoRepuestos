@model G9MotoRepuestos.Models.Usuario
@{
    ViewData["Title"] = "Editar Perfil | Moto Repuestos Rojas";
}

@* Importación de Oswald *@
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/usuarios/EditarPerfil.css" asp-append-version="true" />

<div class="contenedor-perfil-full">
    <div class="tarjeta-registro shadow-lg">

        @* Encabezado Estilo Rojas *@
        <div class="encabezado-estilo-rojas">
            <h2 class="titulo-oswald">CONFIGURACIÓN DE PERFIL</h2>
            <p class="subtitulo-oswald">MOTO REPUESTOS ROJAS</p>
        </div>

        <div class="cuerpo-tarjeta">
            <form asp-action="EditarPerfil" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                @* Campos Ocultos Vitales *@
                <input type="hidden" asp-for="IdUsuario" />
                <input type="hidden" asp-for="IdRol" />
                <input type="hidden" asp-for="Estado" />

                @* Sección de Foto Editable *@
                <div class="seccion-foto-perfil">
                    <div class="marco-foto-circular shadow position-relative">
                        <img id="imgPreview"
                             src="@(string.IsNullOrEmpty(Model.ImagenURL) ? "/images/default-avatar.png" : Model.ImagenURL)"
                             class="foto-renderizada" />

                        <label for="fotoArchivo" class="btn-cambiar-foto" title="Cambiar Foto">
                            <i class="fas fa-camera"></i>
                            <input type="file" name="fotoArchivo" id="fotoArchivo" hidden accept="image/*" onchange="previewImage(event)" />
                        </label>
                    </div>
                    <p class="text-muted small fw-bold mt-2">TOQUE LA CÁMARA PARA SUBIR FOTO</p>
                </div>

                @* Grid de Campos de Usuario *@
                <div class="grid-informacion">

                    <div class="campo-dato">
                        <label class="label-rojo">NOMBRE COMPLETO</label>
                        <input asp-for="NombreCompleto" class="input-rojas" placeholder="Ej: Juan Pérez" required />
                        <span asp-validation-for="NombreCompleto" class="text-danger small"></span>
                    </div>

                    <div class="campo-dato">
                        <label class="label-rojo">CORREO ELECTRÓNICO</label>
                        <input asp-for="Correo" type="email" class="input-rojas" placeholder="correo@ejemplo.com" required />
                        <span asp-validation-for="Correo" class="text-danger small"></span>
                    </div>

                    <div class="campo-dato">
                        <label class="label-rojo">TELÉFONO</label>
                        <input asp-for="Telefono" class="input-rojas" placeholder="8888-8888" />
                    </div>

                    @* CAMPO DE NUEVA CONTRASEÑA CON OJITO *@
                    <div class="campo-dato">
                        <label class="label-rojo">NUEVA CONTRASEÑA (OPCIONAL)</label>
                        <div class="posicion-relativa">
                            <input name="NuevaPassword" id="inputPass" type="password"
                                   class="input-rojas" placeholder="Dejar en blanco para no cambiar"
                                   autocomplete="new-password" />
                            <button type="button" onclick="toggleEditPass()" class="btn-ojo-edit">
                                <i id="iconoOjo" class="fas fa-eye"></i>
                            </button>
                        </div>
                        <small class="text-muted" style="font-size: 0.75rem;">
                            Solo rellene este campo si desea cambiar su clave actual.
                        </small>
                    </div>
                </div>

                @* Botones de Acción *@
                <div class="seccion-botones mt-4">
                    <button type="submit" class="btn-rojo-rojas border-0 shadow-sm">
                        <i class="fas fa-save me-2"></i>GUARDAR CAMBIOS
                    </button>
                    <a asp-action="VerPerfil" class="btn-negro-rojas shadow-sm">
                        CANCELAR
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Función para mostrar/ocultar la contraseña
        function toggleEditPass() {
            const input = document.getElementById("inputPass");
            const icono = document.getElementById("iconoOjo");

            if (input.type === "password") {
                input.type = "text";
                icono.classList.remove("fa-eye");
                icono.classList.add("fa-eye-slash");
            } else {
                input.type = "password";
                icono.classList.remove("fa-eye-slash");
                icono.classList.add("fa-eye");
            }
        }

        // Vista previa inmediata de la imagen seleccionada
        function previewImage(event) {
            const reader = new FileReader();
            reader.onload = function(){
                const output = document.getElementById('imgPreview');
                output.src = reader.result;
            };
            if(event.target.files[0]) {
                reader.readAsDataURL(event.target.files[0]);
            }
        }
    </script>
}