@model G9MotoRepuestos.Models.Servicios
<link rel="stylesheet" href="~/css/Servicios/GestionServicios.css" asp-append-version="true" />

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="panel-modulo p-5">
                <h3 class="fw-bold text-uppercase mb-4 border-bottom pb-2">Registrar Servicio</h3>
                <form asp-action="AgregarServicio" method="post" enctype="multipart/form-data">

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label class="small fw-bold text-uppercase">Nombre del Servicio</label>
                            <input asp-for="Nombre" class="form-control" />
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12 mb-3">
                            <label class="small fw-bold text-uppercase">Descripción</label>
                            <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Descripcion" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="small fw-bold text-uppercase">Precio (₡)</label>
                            <input asp-for="Precio" type="number" step="0.01" class="form-control fw-bold text-danger" />
                            <span asp-validation-for="Precio" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="small fw-bold text-uppercase">Estado Inicial</label>
                            <select asp-for="Estado" class="form-control">
                                <option value="true">Activo</option>
                                <option value="false">Inactivo</option>
                            </select>
                            <span asp-validation-for="Estado" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12 mb-4">
                            <label class="small fw-bold text-uppercase">Subir Imagen</label>
                            <input type="file" name="ImagenFile" class="form-control" accept="image/*" />
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn-rojo flex-grow-1 py-3">GUARDAR EN LISTA</button>
                        <a asp-action="GestionServicios" class="btn btn-dark rounded-0 px-4 py-3 text-decoration-none text-center">CANCELAR</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}