@model G9MotoRepuestos.Models.Servicios
<link rel="stylesheet" href="~/css/Servicios/GestionServicios.css" asp-append-version="true" />

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="panel-modulo p-5">
                <h3 class="fw-bold text-uppercase mb-4 border-bottom pb-2">Editar Servicio #@Model.IdServicio</h3>
                <form asp-action="EditarServicio" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="IdServicio" />
                    <input type="hidden" asp-for="ImagenUrl" />

                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label class="small fw-bold text-uppercase">Nombre del Servicio</label>
                            <input asp-for="Nombre" class="form-control" required />
                        </div>
                        <div class="col-md-12 mb-3">
                            <label class="small fw-bold text-uppercase">Descripción</label>
                            <textarea asp-for="Descripcion" class="form-control" rows="3" required></textarea>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="small fw-bold text-uppercase">Precio (₡)</label>
                            <input asp-for="Precio" type="number" class="form-control fw-bold text-danger" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="small fw-bold text-uppercase">Estado</label>
                            <select asp-for="Estado" class="form-control">
                                <option value="true">Activo</option>
                                <option value="false">Inactivo</option>
                            </select>
                        </div>
                        <div class="col-md-12 mb-4">
                            <label class="small fw-bold text-uppercase">Cambiar Imagen (Opcional)</label>
                            <input type="file" name="ImagenFile" class="form-control" />
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn-rojo flex-grow-1 py-3">ACTUALIZAR CAMBIOS</button>
                        <a asp-action="GestionServicios" class="btn btn-dark rounded-0 px-4 py-3 text-decoration-none text-center">VOLVER</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>