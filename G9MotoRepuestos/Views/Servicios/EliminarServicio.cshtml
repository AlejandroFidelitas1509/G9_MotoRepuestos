@model G9MotoRepuestos.Models.Servicios
<link rel="stylesheet" href="~/css/Servicios/GestionServicios.css" asp-append-version="true" />

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="panel-modulo p-5 border-danger border-top border-4 text-center">
                <i class="fas fa-exclamation-triangle text-danger fa-4x mb-4"></i>
                <h3 class="fw-bold text-uppercase">¿Eliminar Servicio?</h3>
                <p class="text-muted">
                    Estás a punto de borrar el servicio: <br>
                    <strong class="text-dark">@Model.Nombre</strong>
                </p>

                <div class="bg-light p-3 mb-4 border border-2">
                    <p class="mb-1 small fw-bold text-uppercase">ID de Registro: #@Model.IdServicio</p>
                    <p class="mb-0 text-danger fw-bold">₡@Model.Precio.ToString("N0")</p>
                </div>

                <form asp-action="EliminarConfirmado" method="post">
                    <input type="hidden" asp-for="IdServicio" />
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-danger rounded-0 py-3 fw-bold">SÍ, ELIMINAR REGISTRO</button>
                        <a asp-action="GestionServicios" class="btn btn-dark rounded-0 py-3">NO, CANCELAR</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>