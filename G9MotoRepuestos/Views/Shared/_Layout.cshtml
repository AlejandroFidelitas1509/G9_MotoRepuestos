@using System.Security.Claims
@{
    var nombreUsuario = User.Identity?.Name;
    var userRole = User.Claims.FirstOrDefault(c => c.Type == "Role" || c.Type == ClaimTypes.Role)?.Value;
    bool esAdmin = string.Equals(userRole, "Admin", StringComparison.OrdinalIgnoreCase);
    bool esVendedor = string.Equals(userRole, "Vendedor", StringComparison.OrdinalIgnoreCase);
    bool esPersonalAdmin = esAdmin || esVendedor;

    var inicialesUsuario = string.IsNullOrWhiteSpace(nombreUsuario)
        ? "U"
        : string.Concat((nombreUsuario ?? "")
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2)
            .Select(p => p[0].ToString().ToUpper()));

    var controladorActual = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Moto Repuestos Rojas</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/paleta/Colores.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    @if (esPersonalAdmin)
    {
        <style>
            html, body {
                background: #e8edf5 !important;
                color: #1a202c;
            }

            .admin-shell {
                display: flex;
                min-height: 100vh;
            }

            /* ── Sidebar ── */
            .admin-sidebar {
                width: 240px;
                min-width: 240px;
                background: #0f0f16;
                border-right: 1px solid rgba(255,255,255,.06);
                display: flex;
                flex-direction: column;
                position: fixed;
                top: 0;
                left: 0;
                height: 100vh;
                z-index: 1000;
                overflow-y: auto;
            }

                .admin-sidebar::-webkit-scrollbar {
                    width: 4px;
                }

                .admin-sidebar::-webkit-scrollbar-thumb {
                    background: rgba(255,255,255,.1);
                    border-radius: 99px;
                }

            .sidebar-brand {
                padding: 20px;
                border-bottom: 1px solid rgba(255,255,255,.06);
                display: flex;
                align-items: center;
                gap: 11px;
                text-decoration: none;
            }

                .sidebar-brand:hover {
                    text-decoration: none;
                }

            .brand-mark {
                width: 38px;
                height: 38px;
                border-radius: 10px;
                overflow: hidden;
                flex-shrink: 0;
                display: flex;
                align-items: center;
                justify-content: center;
                background: #A32D2D;
            }

                .brand-mark img {
                    width: 100%;
                    height: 100%;
                    object-fit: cover;
                }

            .b-name {
                font-size: 13px;
                font-weight: 700;
                color: #fff;
                line-height: 1.2;
            }

            .b-role {
                font-size: 10.5px;
                color: rgba(255,255,255,.3);
            }

            .nav-section-lbl {
                font-size: 9.5px;
                letter-spacing: .1em;
                text-transform: uppercase;
                color: rgba(255,255,255,.2);
                padding: 16px 20px 5px;
                font-weight: 700;
            }

            .s-link {
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 9px 20px;
                font-size: 13px;
                color: rgba(255,255,255,.42);
                text-decoration: none;
                border-right: 2px solid transparent;
                transition: background .15s, color .15s;
            }

                .s-link i {
                    font-size: 14px;
                    width: 17px;
                    text-align: center;
                    flex-shrink: 0;
                }

                .s-link:hover {
                    background: rgba(255,255,255,.04);
                    color: rgba(255,255,255,.78);
                    text-decoration: none;
                }

                .s-link.active {
                    background: rgba(163,45,45,.16);
                    color: #ff8585;
                    border-right-color: #A32D2D;
                }

                    .s-link.active i {
                        color: #ff8585;
                    }

            .sidebar-footer {
                margin-top: auto;
                padding: 14px 20px;
                border-top: 1px solid rgba(255,255,255,.06);
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .s-avatar {
                width: 30px;
                height: 30px;
                border-radius: 50%;
                background: rgba(163,45,45,.35);
                color: #ff8585;
                font-size: 11px;
                font-weight: 700;
                display: flex;
                align-items: center;
                justify-content: center;
                flex-shrink: 0;
            }

            .s-user-name {
                font-size: 12px;
                font-weight: 600;
                color: rgba(255,255,255,.7);
                line-height: 1.2;
            }

            .s-user-role {
                font-size: 10px;
                color: rgba(255,255,255,.28);
            }

            .s-logout {
                margin-left: auto;
                color: rgba(255,255,255,.22);
                font-size: 15px;
                text-decoration: none;
                transition: color .15s;
            }

                .s-logout:hover {
                    color: rgba(255,255,255,.65);
                }

            /* ── Área principal ── */
            .admin-main {
                margin-left: 240px;
                flex: 1;
                display: flex;
                flex-direction: column;
                min-height: 100vh;
                background: #e8edf5;
            }

            .admin-topbar {
                background: #e8edf5;
                border-bottom: 1px solid #dde3ee;
                padding: 13px 26px;
                display: flex;
                align-items: center;
                justify-content: space-between;
                position: sticky;
                top: 0;
                z-index: 900;
            }

            .topbar-page-title {
                font-size: 15px;
                font-weight: 700;
                color: #1a202c;
                line-height: 1.2;
            }

            .topbar-page-date {
                font-size: 11px;
                color: #8a94a6;
            }

            .topbar-icon-btn {
                width: 32px;
                height: 32px;
                border-radius: 8px;
                background: #dde3ee;
                border: none;
                color: #4a5568;
                display: flex;
                align-items: center;
                justify-content: center;
                cursor: pointer;
                font-size: 14px;
                transition: background .15s, color .15s;
            }

                .topbar-icon-btn:hover {
                    background: #c8d0e0;
                    color: #1a202c;
                }

            .admin-content {
                flex: 1;
                padding: 22px 26px;
            }

            /* ── Formularios para fondo claro ── */
            .form-control, .form-select {
                background: #ffffff !important;
                border: 1px solid #dde3ee !important;
                border-radius: 9px !important;
                color: #1a202c !important;
                font-size: 13.5px !important;
            }

                .form-control::placeholder {
                    color: #8a94a6 !important;
                }

                .form-control:focus, .form-select:focus {
                    background: #ffffff !important;
                    border-color: rgba(201,42,42,.4) !important;
                    box-shadow: 0 0 0 3px rgba(201,42,42,.1) !important;
                    color: #1a202c !important;
                }

                .form-select option {
                    background: #fff;
                    color: #1a202c;
                }

            .form-label {
                font-size: 12px !important;
                color: #8a94a6 !important;
                margin-bottom: 5px !important;
            }

            /* ── Alertas para fondo claro ── */
            .alert-success {
                background: #f0fdf4 !important;
                border: 1px solid #86efac !important;
                color: #166534 !important;
                border-radius: 10px !important;
            }

            .alert-danger {
                background: #fff1f1 !important;
                border: 1px solid #fca5a5 !important;
                color: #991b1b !important;
                border-radius: 10px !important;
            }

            .btn-close {
                filter: none;
            }

            /* ── Botones admin ── */
            .btn-app-primary {
                background: #A32D2D;
                color: #fff;
                border: none;
                border-radius: 9px;
                padding: 8px 16px;
                font-size: 13.5px;
                font-weight: 600;
                cursor: pointer;
                transition: background .15s;
                text-decoration: none;
                display: inline-flex;
                align-items: center;
                gap: 6px;
            }

                .btn-app-primary:hover {
                    background: #8a2424;
                    color: #fff;
                    text-decoration: none;
                }

            .btn-app-secondary {
                background: rgba(255,255,255,.08);
                color: rgba(255,255,255,.75);
                border: 1px solid rgba(255,255,255,.1);
                border-radius: 9px;
                padding: 8px 16px;
                font-size: 13.5px;
                font-weight: 500;
                cursor: pointer;
                transition: background .15s;
                text-decoration: none;
                display: inline-flex;
                align-items: center;
                gap: 6px;
            }

                .btn-app-secondary:hover {
                    background: rgba(255,255,255,.13);
                    color: #fff;
                    text-decoration: none;
                }

            .btn-app-ghost {
                background: transparent;
                color: rgba(255,255,255,.5);
                border: 1px solid rgba(255,255,255,.1);
                border-radius: 9px;
                padding: 8px 16px;
                font-size: 13.5px;
                font-weight: 500;
                cursor: pointer;
                transition: all .15s;
                text-decoration: none;
                display: inline-flex;
                align-items: center;
                gap: 6px;
            }

                .btn-app-ghost:hover {
                    background: rgba(255,255,255,.06);
                    color: rgba(255,255,255,.8);
                    text-decoration: none;
                }

            /* ── Scrollbar ── */
            ::-webkit-scrollbar {
                width: 6px;
                height: 6px;
            }

            ::-webkit-scrollbar-track {
                background: transparent;
            }

            ::-webkit-scrollbar-thumb {
                background: rgba(255,255,255,.1);
                border-radius: 99px;
            }

                ::-webkit-scrollbar-thumb:hover {
                    background: rgba(255,255,255,.2);
                }

            @@media (max-width: 768px) {
                .admin-sidebar {
                    transform: translateX(-100%);
                    transition: transform .25s;
                }

                    .admin-sidebar.open {
                        transform: translateX(0);
                    }

                .admin-main {
                    margin-left: 0;
                }
            }
        </style>
    }
</head>

<body class="@(esPersonalAdmin ? "" : "d-flex flex-column min-vh-100 font-main")">

    @* ══ LAYOUT ADMIN ═══════════════════════════════════════════════ *@
    @if (esPersonalAdmin)
    {
        <div class="admin-shell">
            <nav class="admin-sidebar">

                <a class="sidebar-brand" asp-controller="Home" asp-action="Index">
                    <div class="brand-mark">
                        <img src="~/images/LogoLocal.jpeg" alt="Logo">
                    </div>
                    <div>
                        <div class="b-name">Moto Repuestos</div>
                        <div class="b-role">@(esAdmin ? "Administrador" : "Vendedor")</div>
                    </div>
                </a>

                <div class="nav-section-lbl">Principal</div>

                <a class="s-link @(controladorActual == "Home" ? "active" : "")"
                   asp-controller="Home" asp-action="PanelControl">
                    <i class="fas fa-th-large"></i> Panel de control
                </a>
                <a class="s-link @(controladorActual == "Ventas" ? "active" : "")"
                   asp-controller="Ventas" asp-action="Index">
                    <i class="fas fa-shopping-bag"></i> Ventas
                </a>
                <a class="s-link @(controladorActual == "Clientes" ? "active" : "")"
                   asp-controller="Clientes" asp-action="Index">
                    <i class="fas fa-users"></i> Clientes
                </a>
                <a class="s-link @(controladorActual == "Inventario" ? "active" : "")"
                   asp-controller="Inventario" asp-action="Index">
                    <i class="fas fa-boxes"></i> Inventario
                </a>
                <a class="s-link @(controladorActual == "Citas" ? "active" : "")"
                   asp-controller="Citas" asp-action="Index">
                    <i class="fas fa-calendar-check"></i> Gestión de citas
                </a>
                <a class="s-link @(controladorActual == "Contabilidad" ? "active" : "")"
                   asp-controller="Contabilidad" asp-action="Index">
                    <i class="fas fa-chart-line"></i> Contabilidad
                </a>

                <div class="nav-section-lbl">Análisis</div>

                <a class="s-link @(controladorActual == "Reportes" ? "active" : "")"
                   asp-controller="Reportes" asp-action="Index">
                    <i class="fas fa-file-alt"></i> Reportes
                </a>

                @if (esAdmin)
                {
                    <div class="nav-section-lbl">Sistema</div>
                    <a class="s-link @(controladorActual == "Usuarios" ? "active" : "")"
                       asp-controller="Usuarios" asp-action="Index">
                        <i class="fas fa-user-cog"></i> Usuarios
                    </a>
                    <a class="s-link @(controladorActual == "Configuracion" ? "active" : "")"
                       asp-controller="Configuracion" asp-action="Index">
                        <i class="fas fa-sliders-h"></i> Configuración
                    </a>
                }

                <div class="sidebar-footer">
                    <div class="s-avatar">@inicialesUsuario</div>
                    <div>
                        <div class="s-user-name">@(nombreUsuario ?? "Usuario")</div>
                        <div class="s-user-role">@(esAdmin ? "Admin" : "Vendedor")</div>
                    </div>
                    <a asp-controller="Account" asp-action="Logout" class="s-logout" title="Cerrar sesión">
                        <i class="fas fa-sign-out-alt"></i>
                    </a>
                </div>
            </nav>

            <div class="admin-main">
                <header class="admin-topbar">
                    <div>
                        <div class="topbar-page-date">
                            @DateTime.Now.ToString("dd 'de' MMMM, yyyy", new System.Globalization.CultureInfo("es-CR"))
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <button class="topbar-icon-btn" title="Notificaciones">
                            <i class="fas fa-bell"></i>
                        </button>
                        <div class="s-avatar ms-1" style="cursor:default" title="@nombreUsuario">
                            @inicialesUsuario
                        </div>
                    </div>
                </header>

                <main class="admin-content">
                    @RenderBody()
                </main>
            </div>
        </div>
    }

    @* ══ LAYOUT CLIENTE (original intacto) ══════════════════════════ *@
