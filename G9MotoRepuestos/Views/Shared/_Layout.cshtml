                    <a asp-action="Catalogo" asp-controller="Home" asp-route-categoria="Accesorios"
                       class="list-group-item list-group-item-action py-3 border-secondary border-bottom"
                       style="background-color:transparent !important;color:white !important;font-family:'Oswald',sans-serif !important;">
                        Accesorios
                    </a>
                    <a asp-action="Catalogo" asp-controller="Home" asp-route-categoria="Aceites"
                       class="list-group-item list-group-item-action py-3 border-secondary border-bottom"
                       style="background-color:transparent !important;color:white !important;font-family:'Oswald',sans-serif !important;">
                        Aceites y Lubricantes
                    </a>
                </div>
                <div class="p-3 border-top border-secondary mt-auto" style="background-color:rgba(0,0,0,0.3) !important;">
                    <a asp-controller="Home" asp-action="Nosotros"
                       class="list-group-item list-group-item-action border-0 rounded"
