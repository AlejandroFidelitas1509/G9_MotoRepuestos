@using System.Security.Claims
@{
    var nombreUsuario = User.Identity?.Name;
    var userRole = User.Claims.FirstOrDefault(c => c.Type == "Role" || c.Type == ClaimTypes.Role)?.Value;
    bool esAdmin = string.Equals(userRole, "Admin", StringComparison.OrdinalIgnoreCase);
    bool esVendedor = string.Equals(userRole, "Vendedor", StringComparison.OrdinalIgnoreCase);
    bool esPersonalAdmin = esAdmin || esVendedor;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Moto Repuestos Rojas</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

    <link rel="stylesheet" href="~/css/paleta/Colores.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body class="d-flex flex-column min-vh-100 font-main">

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-rojas shadow mb-0 py-2">
            <div class="container-fluid">
                @if (!esPersonalAdmin)
                {
                    <button class="btn btn-outline-light me-3 border-2 fw-bold"
                            type="button"
                            data-bs-toggle="offcanvas"
                            data-bs-target="#menuCategorias">
                        <i class="fas fa-bars"></i> <span class="d-none d-md-inline ms-1">Categorías</span>
                    </button>
                }

                <a class="navbar-brand fw-bold d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <img src="~/images/LogoLocal.jpeg" alt="Logo" width="45" height="45" class="rounded me-2 border border-white border-1">
                    <span class="d-none d-sm-inline">MOTO REPUESTOS ROJAS</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navMain">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            @if (esPersonalAdmin)
                            {
                                <a class="nav-link text-white fw-bold" asp-controller="Home" asp-action="PanelControl">PANEL DE CONTROL</a>
                            }
                            else
                            {
                                <a class="nav-link text-white fw-bold" asp-controller="Home" asp-action="Catalogo">CATÁLOGO</a>
                            }
                        </li>
                    </ul>

                    @if (!esPersonalAdmin)
                    {
                        <form class="d-flex mx-auto my-2 my-lg-0" asp-controller="Home" asp-action="Catalogo" method="get" style="flex: 1; max-width: 450px;">
                            <div class="input-group">
                                <input name="buscar" class="form-control border-0" type="search" placeholder="¿Qué repuesto buscas?">
                                <button class="btn btn-white text-danger border-0 bg-white" type="submit">
                                    <i class="fas fa-search"></i>
                                </button>
                            </div>
                        </form>
                    }

                    <div class="ms-auto">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="offcanvas offcanvas-start" tabindex="-1" id="menuCategorias"
         style="background-color: #212121 !important; color: white !important;">

        <div class="offcanvas-header border-bottom border-secondary py-3">
            <h5 class="offcanvas-title fw-bold text-danger" style="font-family: 'Oswald', sans-serif !important;">
                <i class="fas fa-motorcycle me-2"></i> PRODUCTOS
            </h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
        </div>

        <div class="offcanvas-body p-0 d-flex flex-column">
            <div class="list-group list-group-flush flex-grow-1">
                <a asp-action="Catalogo" asp-controller="Home" asp-route-categoria="Motor"
                   class="list-group-item list-group-item-action py-3 border-secondary border-bottom"
                   style="background-color: transparent !important; color: white !important; font-family: 'Oswald', sans-serif !important; transition: 0.3s;">
                    Repuestos de Motor
                </a>
                <a asp-action="Catalogo" asp-controller="Home" asp-route-categoria="Accesorios"
                   class="list-group-item list-group-item-action py-3 border-secondary border-bottom"
                   style="background-color: transparent !important; color: white !important; font-family: 'Oswald', sans-serif !important; transition: 0.3s;">
                    Accesorios
                </a>
                <a asp-action="Catalogo" asp-controller="Home" asp-route-categoria="Aceites"
                   class="list-group-item list-group-item-action py-3 border-secondary"
                   style="background-color: transparent !important; color: white !important; font-family: 'Oswald', sans-serif !important; transition: 0.3s;">
                    Aceites y Lubricantes
                </a>
            </div>

            <div class="sidebar-footer p-3 border-top border-secondary mt-auto" style="background-color: rgba(0,0,0,0.3) !important;">
                <a asp-controller="Home" asp-action="Nosotros"
                   class="list-group-item list-group-item-action border-0 rounded"
                   style="background-color: transparent !important; color: white !important; font-family: 'Oswald', sans-serif !important;">
                    <i class="fas fa-info-circle me-2 text-info"></i> Sobre Nosotros
                </a>
            </div>
        </div>
    </div>

    <main role="main" class="flex-shrink-0">
        @RenderBody()
    </main>

    <footer class="bg-dark text-white pt-4 pb-2 border-top border-danger border-4 mt-auto">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-4 text-center text-md-start mb-3 mb-md-0">
                    <h6 class="text-uppercase fw-bold text-danger mb-1 small">Moto Repuestos Rojas</h6>
                    <p class="small text-secondary mb-0" style="font-size: 0.75rem;">Calidad y asesoría honesta en Mercedes Norte desde 2024.</p>
                </div>
                <div class="col-md-5 text-center mb-3 mb-md-0">
                    <div class="d-inline-block text-start">
                        <p class="small mb-0" style="font-size: 0.8rem;"><i class="fas fa-map-marker-alt text-danger me-2"></i>Mercedes Norte, Heredia</p>
                        <p class="small mb-0" style="font-size: 0.8rem;"><i class="fab fa-whatsapp text-success me-2"></i>+506 7243-2805</p>
                    </div>
                </div>
                <div class="col-md-3 text-center text-md-end">
                    <a href="https://wa.me/50672432805" target="_blank" class="social-icon-sm me-2" style="color: #25D366; font-size: 1.2rem;"><i class="fab fa-whatsapp"></i></a>
                    <a href="https://www.facebook.com/share/1831P2NdY6/" target="_blank" class="social-icon-sm me-2" style="color: #1877F2; font-size: 1.2rem;"><i class="fab fa-facebook-f"></i></a>
                    <a href="https://www.instagram.com/motorepuestosrojas" target="_blank" class="social-icon-sm" style="color: #E4405F; font-size: 1.2rem;"><i class="fab fa-instagram"></i></a>
                </div>
            </div>
            <hr class="my-3 border-secondary opacity-25">
            <div class="row pb-2">
                <div class="col-12 text-center">
                    <p class="mb-0 text-secondary" style="font-size: 0.7rem;">© 2026 <strong>Moto Repuestos Rojas</strong>. Pasión por las motos.</p>
                </div>
            </div>
        </div>
    </footer>

    <div class="offcanvas offcanvas-end border-0 shadow-lg rounded-start-4" tabindex="-1" id="offcanvasChat">
        <div class="offcanvas-header bg-dark text-white py-4">
            <h5 class="offcanvas-title fw-bold"><i class="fas fa-robot text-danger me-2"></i>Asistente Rojas</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
        </div>
        <div class="offcanvas-body d-flex flex-column bg-light">
            <div class="flex-grow-1 overflow-auto p-3" id="chatMessages">
                <div class="text-center text-muted small mb-3">Hoy</div>
                <div class="d-flex mb-3">
                    <div class="bg-white p-3 rounded-3 shadow-sm border-start border-danger border-3" style="max-width: 85%;">
                        <p class="mb-0 small">¡Hola! Bienvenido a Moto Repuestos Rojas. ¿En qué te puedo ayudar hoy?</p>
                    </div>
                </div>
            </div>
            <div class="border-top pt-3 mt-auto">
                <form id="chatForm" class="d-flex bg-white p-1 rounded-pill shadow-sm border">
                    <input type="text" id="chatInput" class="form-control border-0 bg-transparent ms-2 shadow-none" placeholder="Escribe un mensaje...">
                    <button type="submit" class="btn btn-danger rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; flex-shrink: 0;">
                        <i class="fas fa-paper-plane"></i>
                    </button>
                </form>
            </div>
        </div>
    </div>

    <button id="btnAbrirChat" class="chat-float shadow-lg" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasChat" aria-label="Abrir Chat">
        <i class="fas fa-comment-dots"></i>
    </button>

    <a href="https://wa.me/50672432805" class="whatsapp-float shadow-lg" target="_blank">
        <i class="fab fa-whatsapp"></i>
    </a>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/chatbox/ChatBox.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>