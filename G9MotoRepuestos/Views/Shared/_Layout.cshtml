                    </div>
                    <div class="col-md-3 text-center text-md-end">
                        <a href="https://wa.me/50672432805" target="_blank" style="color:#25D366;font-size:1.2rem;margin-right:.5rem"><i class="fab fa-whatsapp"></i></a>
                        <a href="https://www.facebook.com/share/1831P2NdY6/" target="_blank" style="color:#1877F2;font-size:1.2rem;margin-right:.5rem"><i class="fab fa-facebook-f"></i></a>
                        <a href="https://www.instagram.com/motorepuestosrojas" target="_blank" style="color:#E4405F;font-size:1.2rem"><i class="fab fa-instagram"></i></a>
                    </div>
                </div>
                <hr class="my-3 border-secondary opacity-25">
                <div class="text-center">
                    <p class="mb-0 text-secondary" style="font-size:0.7rem">© 2026 <strong>Moto Repuestos Rojas</strong>. Pasión por las motos.</p>
                </div>
            </div>
        </footer>

        <div class="offcanvas offcanvas-end border-0 shadow-lg rounded-start-4" tabindex="-1" id="offcanvasChat">
            <div class="offcanvas-header bg-dark text-white py-4">
                <h5 class="offcanvas-title fw-bold"><i class="fas fa-robot text-danger me-2"></i>Asistente Rojas</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
            </div>
            <div class="offcanvas-body d-flex flex-column bg-light">
                <div class="flex-grow-1 overflow-auto p-3" id="chatMessages">
                    <div class="text-center text-muted small mb-3">Hoy</div>
                    <div class="d-flex mb-3">
                        <div class="bg-white p-3 rounded-3 shadow-sm border-start border-danger border-3" style="max-width:85%">
                            <p class="mb-0 small">¡Hola! ¿Deseas agendar un servicio o buscas algún repuesto específico?</p>
                        </div>
                    </div>
                </div>
                <div class="border-top pt-3 mt-auto">
                    <form id="chatForm" class="d-flex bg-white p-1 rounded-pill shadow-sm border">
                        <input type="text" id="chatInput" class="form-control border-0 bg-transparent ms-2 shadow-none" placeholder="Escribe un mensaje...">
                        <button type="submit" class="btn btn-danger rounded-circle d-flex align-items-center justify-content-center" style="width:40px;height:40px;flex-shrink:0">
                            <i class="fas fa-paper-plane"></i>
