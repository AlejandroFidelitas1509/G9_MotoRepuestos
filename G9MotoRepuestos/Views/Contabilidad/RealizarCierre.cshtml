@using MR.Abstracciones.EntidadesParaUI
@model CierreContableDto

@{
    ViewData["Title"] = "Realizar Cierre";
}

<div class="container-fluid py-4">
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="fw-bold text-danger mb-1">Realizar cierre contable</h2>
                    <p class="text-muted mb-0">Define el período del cierre y registra el balance del rango seleccionado.</p>
                </div>

                <a asp-controller="Contabilidad" asp-action="Index" class="btn btn-outline-secondary rounded-3">
                    Volver
                </a>
            </div>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show rounded-3" role="alert">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="alert alert-warning rounded-3 mb-4">
                Los totales de ingresos, egresos y balance se calculan automáticamente según las fechas indicadas.
            </div>

            <form asp-action="RealizarCierre" method="post">
                @Html.AntiForgeryToken()

                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="FechaInicio" class="form-label">Fecha inicio</label>
                        <input asp-for="FechaInicio" type="date" class="form-control rounded-3"
                               value="@Model.FechaInicio.ToString("yyyy-MM-dd")" />
                    </div>

                    <div class="col-md-4">
                        <label asp-for="FechaFin" class="form-label">Fecha fin</label>
                        <input asp-for="FechaFin" type="date" class="form-control rounded-3"
                               value="@Model.FechaFin.ToString("yyyy-MM-dd")" />
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Tipo" class="form-label">Tipo de cierre</label>
                        <select asp-for="Tipo" class="form-select rounded-3">
                            <option value="Diario">Diario</option>
                            <option value="Semanal">Semanal</option>
                            <option value="Mensual">Mensual</option>
                            <option value="Personalizado">Personalizado</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="FechaRegistro" class="form-label">Fecha de registro</label>
                        <input asp-for="FechaRegistro" type="datetime-local" class="form-control rounded-3"
                               value="@Model.FechaRegistro.ToString("yyyy-MM-ddTHH:mm")" readonly />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Usuario</label>
                        <input type="text" class="form-control rounded-3" value="Se asigna automáticamente al guardar" readonly />
                    </div>

                    <div class="col-12 pt-2">
                        <button type="submit" class="btn btn-danger rounded-3">
                            Guardar cierre
                        </button>

                        <a asp-controller="Contabilidad" asp-action="Index" class="btn btn-secondary rounded-3 ms-2">
                            Cancelar
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>