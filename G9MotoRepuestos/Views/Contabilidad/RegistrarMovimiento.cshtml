@using MR.Abstracciones.EntidadesParaUI
@model MovimientoFinancieroDto

@{
    ViewData["Title"] = "Registrar Movimiento";
}

<div class="container-fluid py-4">
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="fw-bold text-danger mb-1">Registrar movimiento</h2>
                    <p class="text-muted mb-0">Agrega un ingreso o egreso manual al módulo contable.</p>
                </div>

                <a asp-controller="Contabilidad" asp-action="Index" class="btn btn-outline-secondary rounded-3">
                    Volver
                </a>
            </div>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show rounded-3" role="alert">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <form asp-action="RegistrarMovimiento" method="post">
                @Html.AntiForgeryToken()

                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="Tipo" class="form-label">Tipo</label>
                        <select asp-for="Tipo" class="form-select rounded-3">
                            <option value="">Seleccione...</option>
                            <option value="Ingreso">Ingreso</option>
                            <option value="Egreso">Egreso</option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Categoria" class="form-label">Categoría</label>
                        <input asp-for="Categoria" class="form-control rounded-3" placeholder="Ej: Caja chica, Gasto operativo, Ajuste..." />
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Monto" class="form-label">Monto</label>
                        <input asp-for="Monto" type="number" step="0.01" min="0.01" class="form-control rounded-3" />
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Fecha" class="form-label">Fecha</label>
                        <input asp-for="Fecha" type="datetime-local" class="form-control rounded-3"
                               value="@Model.Fecha.ToString("yyyy-MM-ddTHH:mm")" />
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Origen" class="form-label">Origen</label>
                        <select asp-for="Origen" class="form-select rounded-3">
                            <option value="Manual">Manual</option>
                            <option value="Ajuste">Ajuste</option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="IdReferencia" class="form-label">Id de referencia</label>
                        <input asp-for="IdReferencia" type="number" class="form-control rounded-3" placeholder="Opcional" />
                    </div>

                    <div class="col-12">
                        <label asp-for="Descripcion" class="form-label">Descripción</label>
                        <textarea asp-for="Descripcion" rows="4" class="form-control rounded-3"
                                  placeholder="Describe el movimiento..."></textarea>
                    </div>

                    <div class="col-12 d-flex gap-2 pt-2">
                        <button type="submit" class="btn btn-danger rounded-3">
                            Guardar movimiento
                        </button>

                        <a asp-controller="Contabilidad" asp-action="Index" class="btn btn-secondary rounded-3">
                            Cancelar
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>